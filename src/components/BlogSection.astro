---
type BlogPost = {
	tag: string;
	title: string;
	excerpt: string;
	image: string;
	variant?: string;
};

interface Props {
	id?: string;
	posts: BlogPost[];
	eyebrow?: string;
	title?: string;
	description?: string;
	showIntro?: boolean;
}

const {
	id = 'blog',
	posts,
	eyebrow = 'Blog',
	title = 'Insights & Updates',
	description = 'Our freshest thoughts on the latest trends, ongoing work, and what is coming next.',
	showIntro = true,
} = Astro.props as Props;
---

<section class="blog-section" id={id}>
	{
		showIntro && (
			<div class="blog-section__intro">
				<div>
					<p class="blog-section__tag">{eyebrow}</p>
					<h2>{title}</h2>
				</div>
				<p>{description}</p>
			</div>
		)
	}

	<div class="blog-section__grid" class:list={{ 'blog-section__grid--no-intro': !showIntro }}>
		{
			posts.map((post) => (
				<article class:list={['blog-card', post.variant && `blog-card--${post.variant}`]} style={`--blog-card-image:url(${post.image})`}>
					<div class="blog-card__tag">{post.tag}</div>
					<div class="blog-card__spacer" aria-hidden="true"></div>
					<div class="blog-card__footer">
						<div class="blog-card__content">
							<h3>{post.title}</h3>
							<p>{post.excerpt}</p>
						</div>
						<a href="#contact" class="blog-card__link">Read More <span aria-hidden="true">→</span></a>
					</div>
				</article>
			))
		}
	</div>
</section>

<style>
	.blog-section {
		padding: 5rem var(--page-pad, clamp(1rem, 4vw, 5rem));
	}

	.blog-section__intro {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem 2rem;
		align-items: end;
	}

	.blog-section__tag {
		margin: 0 0 0.75rem;
		font-size: 1.25rem;
		color: var(--blue, #00a1dc);
	}

	.blog-section__intro h2 {
		margin: 0;
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.blog-section__intro > p:last-child {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.35;
		color: var(--muted, #5b5b5b);
	}

	.blog-section__grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.5rem;
		margin-top: 1.875rem;
	}

	.blog-section__grid--no-intro {
		margin-top: 0;
	}

	.blog-card {
		position: relative;
		min-height: 24.5rem;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		align-items: flex-start;
		gap: 0.5rem;
		border-radius: 0.5rem;
		border: 1px solid #b0b0b0;
		color: white;
		overflow: hidden;
		isolation: isolate;
		background: white;
	}

	.blog-card::before {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
		pointer-events: none;
		z-index: -2;
		background: var(--blog-card-image) center / cover no-repeat, white;
	}

	.blog-card > * {
		position: relative;
		z-index: 1;
	}

	.blog-card__tag {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 0.375rem 0.5rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.92);
		font-size: 0.625rem;
		font-weight: 600;
		line-height: 1;
	}

	.blog-card__spacer {
		flex: 0 0 auto;
		width: 100%;
		min-height: 0;
		aspect-ratio: 652 / 384;
	}

	.blog-card__footer {
		position: relative;
		isolation: isolate;
		width: calc(100% + 2rem);
		margin: 0 -1rem -1rem;
		padding: 0 1rem 1rem;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5rem;
		background: none;
	}

	.blog-card__footer::before {
		content: '';
		position: absolute;
		inset: 0;
		top: calc(-1 * var(--blog-card-fade-lift, 4.75rem));
		background: var(--blog-card-overlay, transparent);
		pointer-events: none;
		z-index: -1;
	}

	.blog-card__content {
		max-width: 16.875rem;
		min-height: 7.5rem;
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.blog-card h3 {
		margin: 0;
		max-width: 16.875rem;
		font-size: 1.25rem;
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.blog-card p {
		margin: 0;
		color: white;
		font-size: 0.875rem;
		line-height: 1.12;
		max-width: 16.875rem;
		display: -webkit-box;
		-webkit-line-clamp: 4;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: 2.625rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 1);
		font-size: 1.125rem;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
		color: white;
	}

	.blog-card--metocean {
		--blog-card-overlay: linear-gradient(180deg, rgba(0, 161, 220, 0) 0%, rgba(20, 93, 133, 0.72) 77.895%);
	}

	.blog-card--land {
		--blog-card-overlay: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.4) 50%);
	}

	.blog-card--warning {
		--blog-card-fade-lift: 4.75rem;
		--blog-card-overlay: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.32) 50%);
	}

	.blog-card--warning h3,
	.blog-card--warning p {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card--warning h3 {
		-webkit-line-clamp: 3;
	}

	.blog-card--warning p {
		-webkit-line-clamp: 4;
	}

	.blog-card--solar {
		--blog-card-overlay: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.32) 50%);
	}

	.blog-card--bright {
		--blog-card-overlay: linear-gradient(180deg, rgba(0, 161, 220, 0.1) 0%, rgba(20, 93, 133, 0.9) 78%);
	}

	.blog-card--dark {
		--blog-card-overlay: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.48) 100%);
	}

	.blog-card--mono {
		--blog-card-overlay: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.4) 100%);
	}

	.blog-card--mono::before {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.06)),
			var(--blog-card-image) center / cover no-repeat,
			white;
		filter: grayscale(1);
	}

	@media (max-width: 72rem) {
		.blog-section__intro,
		.blog-section__grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 40rem) {
		.blog-section {
			padding-top: 3rem;
			padding-bottom: 3rem;
		}

		.blog-card h3 {
			font-size: 1.75rem;
		}
	}
</style>
