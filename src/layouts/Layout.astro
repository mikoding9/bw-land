---
const {
	title = 'Bhumi Warih',
	activeNav = '',
	footerShape = '',
	footerGlossaryHref = '/glossary',
	footerLegalHref = '/legal-and-privacy',
} = Astro.props;

const topNavLogo = '/figma/top-nav-logo.svg';
const topNavLogoScrolled = '/figma/top-nav-logo-scrolled.svg';
const mobileOverlayLogo = '/figma/mobile-menu-logo.svg';
const footerWavePattern = '/figma/footer-wave-union.svg';
const footerSocials = [
	{
		label: 'Facebook',
		href: 'https://www.facebook.com/profile.php?id=100009719311453',
		shortLabel: 'f',
	},
	{
		label: 'LinkedIn',
		href: 'https://www.linkedin.com/company/bwgeohydromatics/posts/?feedView=all',
		icon: '/figma/social-linkedin.svg',
	},
];

const navItems = [
	{ key: 'home', label: 'Home', href: '/' },
	{
		key: 'service',
		label: 'Services',
		href: '/service/metocean',
		children: [
			{ label: 'Metocean', href: '/service/metocean' },
			{ label: 'DSS', href: '/service/dss' },
			{ label: 'Extended', href: '/service/extended' },
		],
	},
	{ key: 'industry', label: 'Industries', href: '/industry' },
	{ key: 'about', label: 'About', href: '/about' },
	{ key: 'insight', label: 'Insight', href: '/insight' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#01A1DC" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Host+Grotesk:wght@400;500;600&family=Inter:opsz,wght@14..32,400;500&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-topbar">
			<button
				type="button"
				class="site-topbar__menu-toggle"
				aria-label="Open navigation menu"
				aria-expanded="false"
				aria-controls="mobile-nav"
			>
				<span class="site-topbar__menu-toggle-lines" aria-hidden="true"></span>
			</button>
			<nav class="site-topbar__menu" aria-label="Primary">
				{
					navItems.map((item) =>
						item.children ? (
							<div class="site-dropdown">
								<a
									href={item.href}
									class:list={[
										'site-pill',
										'site-pill--ghost',
										'site-dropdown__trigger',
										activeNav === item.key && 'is-active',
									]}
									aria-current={activeNav === item.key ? 'page' : undefined}
									aria-haspopup="menu"
								>
									{item.label} <span aria-hidden="true">▾</span>
								</a>
								<div class="site-dropdown__menu" role="menu" aria-label="Service links">
									{
										item.children.map((child) => (
											<a href={child.href} class="site-dropdown__item" role="menuitem">
												{child.label}
											</a>
										))
									}
								</div>
							</div>
						) : (
							<a
								href={item.href}
								class:list={['site-pill', 'site-pill--ghost', activeNav === item.key && 'is-active']}
								aria-current={activeNav === item.key ? 'page' : undefined}
							>
								{item.label}
							</a>
						)
					)
				}
			</nav>

			<a href="/" class="site-topbar__brand" aria-label="Bhumi Warih home">
				<img
					class="site-brand-mark"
					src={topNavLogo}
					alt=""
					data-logo-default={topNavLogo}
					data-logo-scrolled={topNavLogoScrolled}
				/>
			</a>

			<div class="site-topbar__actions">
				<a href="#contact" class="site-pill site-pill--ghost">ID | EN</a>
				<a href="#contact" class="site-pill site-pill--solid">Contact Us <span aria-hidden="true">→</span></a>
			</div>
		</header>
		<nav id="mobile-nav" class="site-topbar__mobile-panel" aria-label="Mobile Primary">
			<div class="site-topbar__mobile-top">
				<button
					type="button"
					class="site-topbar__mobile-close"
					aria-label="Close navigation menu"
				>
					<span class="site-topbar__mobile-close-lines" aria-hidden="true"></span>
				</button>
				<a href="/" class="site-topbar__mobile-brand" aria-label="Bhumi Warih home">
					<img class="site-topbar__mobile-brand-mark" src={mobileOverlayLogo} alt="" />
				</a>
				<div class="site-topbar__mobile-top-spacer" aria-hidden="true"></div>
			</div>
			<div class="site-topbar__mobile-nav-list">
				{
					navItems.map((item) => (
						<a href={item.href} class:list={['site-topbar__mobile-link', activeNav === item.key && 'is-active']}>
							{item.label}
						</a>
					))
				}
			</div>
			<div class="site-topbar__mobile-actions">
				<a href="#contact" class="site-topbar__mobile-cta">Contact Us</a>
				<a href="#contact" class="site-topbar__mobile-lang">ID | EN</a>
			</div>
			<div class="site-topbar__mobile-footer">
				<div class="site-topbar__mobile-footer-links">
					<a href={footerLegalHref}>Legal &amp; Privacy</a>
					<a href={footerGlossaryHref}>Glossary</a>
					<a href="#contact">Careers</a>
				</div>
				<div class="site-topbar__mobile-footer-line" aria-hidden="true"></div>
				<div class="site-topbar__mobile-footer-socials">
					{
						footerSocials.map((social) => (
							<a href={social.href} aria-label={social.label} target="_blank" rel="noreferrer">
								{
									social.icon ? (
										<span class="site-footer__social-icon" style={`--social-icon:url(${social.icon})`} aria-hidden="true"></span>
									) : (
										<span class="site-footer__social-badge" aria-hidden="true">{social.shortLabel}</span>
									)
								}
							</a>
						))
					}
				</div>
				<div class="site-topbar__mobile-footer-line" aria-hidden="true"></div>
				<div class="site-topbar__mobile-footer-meta">
					<div>PT. Bhumi Warih Geohydromatics</div>
					<div>Copyright © 2026</div>
				</div>
			</div>
		</nav>

		<slot />

		<section class="layout-contact" id="contact">
			<img class="layout-contact__shape" src={footerWavePattern} alt="" />
			<div class="layout-contact__inner">
				<div class="layout-contact__copy">
					<p class="layout-contact__eyebrow">/Contact Us</p>
					<h2>Planning an Offshore Project? Let&apos;s Talk About Your Metocean Needs.</h2>
					<address>
						Non Stop Building 2nd Floor Unit 7
						<br />
						Jl. Tubagus Ismail No.40 Bandung
						<br />
						40134
					</address>
				</div>

				<form class="layout-contact__form">
					<div class="layout-contact__grid">
						<label>
							<span class="sr-only">Your Name</span>
							<input type="text" name="name" placeholder="Your Name" />
						</label>
						<label>
							<span class="sr-only">Your Email</span>
							<input type="email" name="email" placeholder="Your Email" />
						</label>
					</div>
					<label>
						<span class="sr-only">Your Message</span>
						<textarea name="message" rows="6" placeholder="Tell us what you need..."></textarea>
					</label>
					<button type="submit" class="site-pill site-pill--solid">Send Message <span aria-hidden="true">→</span></button>
				</form>
			</div>

			<footer class="site-footer" id="glossary">
				<div class="site-footer__links">
					<a href={footerLegalHref}>Legal &amp; Privacy</a>
					<a href={footerGlossaryHref}>Glossary</a>
					<a href="#contact">Careers</a>
					<span>Copyright © 2026</span>
				</div>
				<div class="site-footer__socials">
					{
						footerSocials.map((social) => (
							<a href={social.href} aria-label={social.label} target="_blank" rel="noreferrer">
								{
									social.icon ? (
										<span class="site-footer__social-icon" style={`--social-icon:url(${social.icon})`} aria-hidden="true"></span>
									) : (
										<span class="site-footer__social-badge" aria-hidden="true">{social.shortLabel}</span>
									)
								}
							</a>
						))
					}
				</div>
				<div class="site-footer__company">PT. Bhumi Warih Geohydromatics</div>
			</footer>
		</section>

		<script is:inline>
			const topbar = document.querySelector('.site-topbar');
			const heroTrigger = document.querySelector('[data-nav-hero]');
			const footerTrigger = document.querySelector('.layout-contact');
			const brandMark = document.querySelector('.site-brand-mark');
			const menuToggle = document.querySelector('.site-topbar__menu-toggle');
			const mobilePanel = document.querySelector('.site-topbar__mobile-panel');
			const mobileClose = document.querySelector('.site-topbar__mobile-close');

			if (topbar && heroTrigger && footerTrigger && brandMark instanceof HTMLImageElement) {
				const updateTopbarState = () => {
					const triggerBottom = heroTrigger.getBoundingClientRect().bottom;
					const footerTop = footerTrigger.getBoundingClientRect().top;
					const threshold = topbar.getBoundingClientRect().height;
					const isBetweenHeroAndFooter =
						triggerBottom <= threshold && footerTop > threshold;
					const isScrolled = isBetweenHeroAndFooter;
					topbar.classList.toggle('is-scrolled', isScrolled);
					brandMark.classList.toggle('is-logo-scrolled', isScrolled);
					brandMark.src = isScrolled
						? brandMark.dataset.logoScrolled || brandMark.src
						: brandMark.dataset.logoDefault || brandMark.src;
				};

				updateTopbarState();
				window.addEventListener('scroll', updateTopbarState, { passive: true });
				window.addEventListener('resize', updateTopbarState);
			}

			if (topbar && menuToggle instanceof HTMLButtonElement && mobilePanel instanceof HTMLElement) {
				const closeMobileNav = () => {
					topbar.classList.remove('is-mobile-open');
					menuToggle.setAttribute('aria-expanded', 'false');
					document.body.classList.remove('has-mobile-nav-open');
				};

				menuToggle.addEventListener('click', () => {
					const isOpen = topbar.classList.toggle('is-mobile-open');
					menuToggle.setAttribute('aria-expanded', String(isOpen));
					document.body.classList.toggle('has-mobile-nav-open', isOpen);
				});

				if (mobileClose instanceof HTMLButtonElement) {
					mobileClose.addEventListener('click', closeMobileNav);
				}

				mobilePanel.querySelectorAll('a').forEach((link) =>
					link.addEventListener('click', closeMobileNav)
				);

				window.addEventListener('resize', () => {
					if (window.innerWidth > 640) closeMobileNav();
				});
			}
		</script>
	</body>
</html>

<style>
	:global(html) {
		scroll-behavior: smooth;
		scroll-padding-top: 7rem;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: #f0ecea;
	}

	body {
		font-family: 'Host Grotesk', 'Inter', sans-serif;
	}

	body.has-mobile-nav-open {
		overflow: hidden;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(a) {
		color: inherit;
	}

	:global(img) {
		max-width: 100%;
	}

	.site-topbar {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		padding: 1rem clamp(1rem, 4vw, 5rem);
		background: transparent;
		box-shadow: none;
		isolation: isolate;
	}

	.site-topbar__menu-toggle,
	.site-topbar__mobile-panel {
		display: none;
	}

	.site-topbar::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -1;
		background: rgba(18, 24, 38, 0.04);
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		opacity: 0;
		transition: opacity 220ms ease;
		pointer-events: none;
	}

	.site-topbar.is-scrolled {
		background: transparent;
	}

	.site-topbar.is-scrolled::before {
		opacity: 1;
	}

	.site-topbar__menu,
	.site-topbar__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.site-topbar__actions {
		justify-content: flex-end;
	}

	.site-dropdown {
		position: relative;
	}

	.site-topbar__brand {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: min(100%, 17.204rem);
		height: 3.5rem;
		text-decoration: none;
	}

	.site-brand-mark {
		display: block;
		width: 2.82rem;
		height: 2.82rem;
		object-fit: contain;
		transition: opacity 220ms ease;
	}

	.site-brand-mark.is-logo-scrolled {
		width: auto;
		height: 100%;
		max-width: 100%;
	}

	.site-pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: 2.625rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		border: 1px solid currentColor;
		font-size: 1.125rem;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
		transition:
			color 220ms ease,
			background-color 220ms ease,
			border-color 220ms ease;
	}

	.site-pill--ghost {
		color: white;
		background: transparent;
	}

	.site-pill--ghost.is-active {
		background: white;
		color: #01a1dc;
		font-weight: 600;
	}

	.site-topbar.is-scrolled .site-topbar__menu .site-pill--ghost {
		color: #0083d5;
		border-color: #0083d5;
	}

	.site-topbar.is-scrolled .site-topbar__menu .site-pill--ghost.is-active {
		background: rgba(0, 131, 213, 0.12);
		color: #0083d5;
		border-color: #0083d5;
	}

	.site-topbar.is-scrolled .site-topbar__actions .site-pill--ghost {
		color: #0083d5;
		border-color: #0083d5;
	}

	.site-dropdown__trigger span {
		font-size: 0.85em;
	}

	.site-dropdown__menu {
		position: absolute;
		top: calc(100% + 0.5rem);
		left: 0;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 12rem;
		padding: 0.5rem;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 1.25rem;
		background: rgba(4, 53, 109, 0.92);
		backdrop-filter: blur(18px);
		box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.2);
		opacity: 0;
		visibility: hidden;
		transform: translateY(0.35rem);
		transition:
			opacity 160ms ease,
			transform 160ms ease,
			visibility 160ms ease;
	}

	.site-dropdown:hover .site-dropdown__menu,
	.site-dropdown:focus-within .site-dropdown__menu {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

	.site-dropdown__item {
		display: block;
		padding: 0.85rem 1rem;
		border-radius: 999px;
		color: white;
		font-size: 1rem;
		line-height: 1;
		text-decoration: none;
	}

	.site-dropdown__item:hover,
	.site-dropdown__item:focus-visible {
		background: white;
		color: #01a1dc;
		outline: none;
	}

	.site-pill--solid {
		color: black;
		background: white;
		border-color: white;
	}

	.site-topbar__menu-toggle {
		align-items: center;
		justify-content: center;
		width: 2.4375rem;
		height: 2rem;
		padding: 0;
		border: 0.75px solid rgba(255, 255, 255, 0.9);
		border-radius: 999px;
		background: transparent;
		color: white;
		cursor: pointer;
	}

	.site-topbar__menu-toggle-lines,
	.site-topbar__menu-toggle-lines::before,
	.site-topbar__menu-toggle-lines::after {
		display: block;
		width: 0.875rem;
		height: 1.5px;
		border-radius: 999px;
		background: currentColor;
		transition:
			transform 180ms ease,
			opacity 180ms ease;
	}

	.site-topbar__menu-toggle-lines {
		position: relative;
	}

	.site-topbar__menu-toggle-lines::before,
	.site-topbar__menu-toggle-lines::after {
		content: '';
		position: absolute;
		left: 0;
	}

	.site-topbar__menu-toggle-lines::before {
		top: -0.25rem;
	}

	.site-topbar__menu-toggle-lines::after {
		top: 0.25rem;
	}

	.site-topbar.is-mobile-open .site-topbar__menu-toggle-lines {
		transform: rotate(45deg);
		background: #0083d5;
	}

	.site-topbar.is-mobile-open .site-topbar__menu-toggle-lines::before {
		transform: rotate(90deg);
		top: 0;
		background: #0083d5;
	}

	.site-topbar.is-mobile-open .site-topbar__menu-toggle-lines::after {
		opacity: 0;
	}

	.site-topbar.is-scrolled .site-topbar__actions .site-pill--solid {
		color: white;
		background: #0083d5;
		border-color: #0083d5;
	}

	.layout-contact {
		position: relative;
		padding: 5rem clamp(1rem, 4vw, 5rem) 2.5rem;
		color: white;
		background: linear-gradient(122deg, #01a1dc 0%, #1952d2 100%);
		overflow: clip;
	}

	.layout-contact__shape {
		position: absolute;
		left: 0;
		bottom: 0;
		height: 100%;
		width: auto;
		max-width: none;
		transform: none;
		opacity: 0.8;
	}

	.layout-contact__inner,
	.site-footer {
		position: relative;
		z-index: 1;
	}

	.layout-contact__inner {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
		align-items: center;
	}

	.layout-contact__copy {
		max-width: 39.25rem;
	}

	.layout-contact__eyebrow {
		margin: 0 0 0.875rem;
		font-size: 1.25rem;
		color: white;
	}

	.layout-contact h2 {
		margin: 0;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.layout-contact address {
		margin-top: 10rem;
		max-width: 20.625rem;
		color: white;
		font-style: normal;
		font-size: 1.25rem;
		line-height: 1.35;
	}

	.layout-contact__form {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.75rem;
	}

	.layout-contact__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		width: 100%;
	}

	.layout-contact label {
		width: 100%;
	}

	.layout-contact input,
	.layout-contact textarea {
		width: 100%;
		box-sizing: border-box;
		padding: 1.5rem 1.25rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.9);
		background: rgba(255, 255, 255, 0.12);
		color: white;
		font: inherit;
		resize: vertical;
	}

	.layout-contact input::placeholder,
	.layout-contact textarea::placeholder {
		color: rgba(255, 255, 255, 0.55);
	}

	.site-footer {
		margin-top: 8.75rem;
		padding-top: 2.5rem;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: 1.5rem;
		align-items: center;
		font-size: 1rem;
	}

	.site-footer__links,
	.site-footer__socials {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.site-footer__links a,
	.site-footer__company {
		color: rgba(241, 245, 236, 0.95);
	}

	.site-footer__socials a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: white;
		text-decoration: none;
	}

	.site-footer__social-icon {
		display: block;
		width: 1.5rem;
		height: 1.5rem;
		background: currentColor;
		-webkit-mask: var(--social-icon) center / contain no-repeat;
		mask: var(--social-icon) center / contain no-repeat;
	}

	.site-footer__social-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		font-size: 1.55rem;
		font-weight: 700;
		line-height: 1;
		text-transform: lowercase;
		transform: translateY(0.03rem);
	}

	.site-footer__company {
		text-align: right;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	@media (max-width: 72rem) {
		.site-topbar,
		.layout-contact__inner,
		.site-footer {
			grid-template-columns: 1fr;
		}

		.site-topbar__menu,
		.site-topbar__actions,
		.site-topbar__brand {
			justify-content: center;
		}

		.site-topbar__brand {
			width: 100%;
		}

		.layout-contact__grid {
			grid-template-columns: 1fr;
		}

		.site-footer__company {
