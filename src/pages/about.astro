---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import aboutHeroBaseImage from '../assets/about/hero-base.jpg';
import aboutServiceImage from '../assets/about/service-image.png';
import { directusStaticToken, directusTeamMembersApiUrl } from '../data/directus';

const heroBand = '/figma/about-hero-band.png';
const heroGraphicA = '/figma/about-hero-graphic-a.svg';
const heroGraphicB = '/figma/about-hero-graphic-b.svg';
const teamShotA = '/figma/about-team-shot-a.png';
const teamShotB = '/figma/about-team-shot-b.png';
const teamShotC = '/figma/about-team-shot-c.png';
const teamShotD = '/figma/about-team-shot-d.png';
const teamShotE = '/figma/about-team-shot-e.png';
const socialLinkedIn = '/figma/social-linkedin.svg';
const socialInstagram = '/figma/social-instagram.svg';
const footerShape = '/figma/about-contact-shape.svg';

const clientAssets = [
	'/figma/about-client-logo-01.png',
	'/figma/about-client-logo-02.png',
	'/figma/about-client-logo-03.png',
	'/figma/about-client-logo-04.png',
	'/figma/about-client-logo-05.png',
	'/figma/about-client-logo-06.png',
	'/figma/about-client-logo-07.png',
	'/figma/about-client-logo-08.png',
	'/figma/about-client-logo-09.png',
	'/figma/about-client-logo-10.png',
	'/figma/about-client-logo-11.png',
	'/figma/about-client-logo-12.png',
	'/figma/about-client-logo-13.png',
	'/figma/about-client-logo-14.png',
	'/figma/about-client-logo-15.png',
	'/figma/about-client-logo-16.png',
	'/figma/about-client-logo-17.png',
	'/figma/about-client-logo-18.png',
];

const teamShots = [teamShotA, teamShotB, teamShotC, teamShotD, teamShotE];
---

<Layout title="BhumiWarih Profile | Bhumi Warih" activeNav="about" footerShape={footerShape}>
	<main class="about-page">
		<section class="about-hero" data-nav-hero>
			<div class="about-hero__bg">
				<div class="about-hero__base-wrap">
					<Image class="about-hero__base" src={aboutHeroBaseImage} alt="" loading="eager" fetchpriority="high" quality={82} />
				</div>
				<img class="about-hero__graphic about-hero__graphic--a" src={heroGraphicA} alt="" />
				<div class="about-hero__band-wrap">
					<img class="about-hero__band" src={heroBand} alt="" />
				</div>
				<img class="about-hero__graphic about-hero__graphic--b" src={heroGraphicB} alt="" />
				<div class="about-hero__veil"></div>
			</div>

			<div class="about-hero__meta">
				Specializing in Information and Knowledge of Meteorological and Oceanographic (MEtocean)
				field.
			</div>

			<div class="about-hero__copy">
				<p class="section-tag section-tag--inverse">/About</p>
				<h1>BhumiWarih Profile</h1>
			</div>
		</section>

		<section class="about-intro">
			<p class="section-tag">What We Do</p>
			<h2>
				Delivering clear ‘picture’ of various parameter and ranges of marine physical environmental
				factors which are of substantial to our client investments.
			</h2>

			<div class="about-intro__columns">
				<div>
					<p class="section-tag">How We Do</p>
					<p>
						We will produce this ‘picture’ as metocean information and knowledge of a given site
						of interest and present them as standard hardcopy report, offline data base retrieval
						system with interactive user interface, regular push-mail report, or online access to
						our operational metocean system, including involvement of front line service.
					</p>
				</div>
				<div>
					<p class="section-tag">Our Mission</p>
					<p>
						BhumiWarih’s mission is to provide support to the improvement of accuracy, security,
						and safety of the coastal and offshore design, planning, and investment.
					</p>
				</div>
			</div>
		</section>

		<section class="service-overview">
			<div class="service-overview__copy">
				<p class="section-tag">Service Overview</p>
				<h3>
					A specialized competence of the company is the capability to involve state-of-the-art
					scientific methods and novel techniques in improving the reliability and merit of marine
					environmental information.
				</h3>
				<p>
					Our core of competences are based on long experience and academic training of its
					personnel in dealing with studies of mean and extreme values of wind, wave, current, and
					tide, for the purpose of design criteria or front end engineering of fix or floating
					structures and underwater constructions, as well as real-time and forecast systems for
					planning and monitoring of sea-state sensitive operations.
				</p>
			</div>
			<div class="service-overview__media">
				<Image
					class="service-overview__image"
					src={aboutServiceImage}
					alt="Offshore instrument in clear water"
					loading="lazy"
					quality={80}
				/>
			</div>
		</section>

		<section class="clients">
			<div class="clients__intro">
				<p class="section-tag">Our Clients</p>
				<h3>We’re Trusted by Government Bodies and Private Sectors Across the Globe</h3>
			</div>

			<div class="clients__grid">
				{
					clientAssets.map((asset) => (
						<div class="clients__logo">
							<img src={asset} alt="" />
						</div>
					))
				}
				<div class="clients__more">and by 999+ More since YYYY</div>
			</div>
		</section>

		<section class="team">
			<div class="team__intro">
				<p class="section-tag">Our Team</p>
				<h3>
					Experiments, diversity in perspective and multi disciplinary set of mind are our beliefs
					in delivering innovative and creative solutions to our client’s problems.
				</h3>

				<div class="team__gallery">
					{teamShots.map((asset) => <img src={asset} alt="" />)}
				</div>

				<p>
					BWgeohydromatics’ key people are entrepreneur researchers, who have been accumulating
					knowledge in theoretical and practical spheres of applications of various disciplines
					covering coastal engineering, environmental science, physical geography, hydrography,
					and oceanography.
				</p>
				<p>
					To date, our key team members are well trained and exposed physical oceanographers with
					strong support from computation and information technology team.
				</p>
			</div>

			<div
				class="team__cards"
				data-team-cards
				data-directus-endpoint={directusTeamMembersApiUrl}
				data-directus-token={directusStaticToken}
				data-linkedin-icon={socialLinkedIn}
				data-instagram-icon={socialInstagram}
			>
				<p class="team__status" data-team-status>Loading team members...</p>
			</div>
		</section>

	</main>
</Layout>

<script is:inline>
	const teamCardsRoot = document.querySelector('[data-team-cards]');

	if (teamCardsRoot instanceof HTMLElement) {
		const endpoint = teamCardsRoot.dataset.directusEndpoint;
		const token = teamCardsRoot.dataset.directusToken;
		const linkedInIcon = teamCardsRoot.dataset.linkedinIcon;
		const instagramIcon = teamCardsRoot.dataset.instagramIcon;

		const buildTeamCard = (member) => {
			const article = document.createElement('article');
			article.className = 'team-card';

			const media = document.createElement('div');
			media.className = 'team-card__media';

			if (member.photo) {
				const image = document.createElement('img');
				image.className = 'team-card__photo';
				image.src = `https://panel.braga.co.id/panel/assets/${member.photo}`;
				image.alt = member.name || 'Bhumi Warih team member';
				image.loading = 'lazy';
				media.appendChild(image);
			} else {
				const photoFallback = document.createElement('div');
				photoFallback.className = 'team-card__photo team-card__photo--empty';
				photoFallback.setAttribute('aria-hidden', 'true');
				media.appendChild(photoFallback);
			}

			article.appendChild(media);

			const body = document.createElement('div');
			body.className = 'team-card__body';

			const role = document.createElement('p');
			role.className = 'team-card__role';
			role.textContent = member.role || 'Team Member';
			body.appendChild(role);

			const name = document.createElement('h4');
			name.textContent = member.name || 'Bhumi Warih Team';
			body.appendChild(name);

			if (member.description && member.description !== '-') {
				const description = document.createElement('p');
				description.textContent = member.description;
				body.appendChild(description);
			}

			const socials = [
				member.linkedin && linkedInIcon
					? { href: member.linkedin, label: 'LinkedIn', icon: linkedInIcon }
					: null,
				member.instagram && instagramIcon
					? { href: member.instagram, label: 'Instagram', icon: instagramIcon }
					: null,
			].filter(Boolean);

			if (socials.length > 0) {
				const socialsWrap = document.createElement('div');
				socialsWrap.className = 'team-card__socials';

				for (const social of socials) {
					const anchor = document.createElement('a');
					anchor.href = social.href;
					anchor.setAttribute('aria-label', social.label);
					anchor.target = '_blank';
					anchor.rel = 'noreferrer';

					const icon = document.createElement('img');
					icon.src = social.icon;
					icon.alt = '';
					anchor.appendChild(icon);
					socialsWrap.appendChild(anchor);
				}

				body.appendChild(socialsWrap);
			}

			article.appendChild(body);
			return article;
		};

		const showStatus = (message) => {
			teamCardsRoot.innerHTML = '';
			const status = document.createElement('p');
			status.className = 'team__status';
			status.textContent = message;
			teamCardsRoot.appendChild(status);
		};

		if (!endpoint || !token) {
			showStatus('Team members are unavailable right now.');
		} else {
			const params = new URLSearchParams({
				sort: 'sort',
				fields: 'id,sort,date_updated,role,name,description,linkedin,instagram,photo',
			});

			fetch(`${endpoint}?${params.toString()}`, {
				headers: {
					Accept: 'application/json',
					Authorization: `Bearer ${token}`,
				},
			})
				.then((response) => {
					if (!response.ok) {
						throw new Error(`Failed to load team members: ${response.status}`);
					}

					return response.json();
				})
				.then((payload) => {
					const members = Array.isArray(payload?.data) ? payload.data : [];
					teamCardsRoot.innerHTML = '';

					if (members.length === 0) {
						showStatus('No team members found.');
						return;
					}

					for (const member of members) {
						teamCardsRoot.appendChild(buildTeamCard(member));
					}
				})
				.catch((error) => {
					console.error('Failed to load team members for /about:', error);
					showStatus('Team members are unavailable right now.');
				});
		}
	}
</script>

<style>
	:global(:root) {
		--bg: #ffffff;
		--paper: #f8f8f8;
		--line: #e7e7e7;
		--text: #151515;
		--muted: #00a1dc;
		--page-pad: clamp(1rem, 4vw, 5rem);
		--about-page-pad: clamp(1rem, 13vw, 11.75rem);
	}

	.about-page {
		background: var(--bg);
		color: var(--text);
	}

	.about-hero {
		position: relative;
		min-height: 56.25rem;
		padding: 2rem var(--page-pad) 3rem;
		overflow: clip;
		color: white;
		background: #031422;
	}

	.about-hero__bg,
	.about-hero__veil {
		position: absolute;
		inset: 0;
	}

	.about-hero__base-wrap,
	.about-hero__band-wrap {
		position: absolute;
	}

	.about-hero__base-wrap {
		inset: 0;
		z-index: 0;
	}

	.about-hero__band-wrap {
		inset: 0;
		z-index: 2;
	}

	.about-hero__base,
	.about-hero__band {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center center;
	}

	.about-hero__band {
		object-fit: cover;
	}

	.about-hero__graphic {
		position: absolute;
		top: 0;
		bottom: 0;
		height: auto;
		min-height: 100%;
		width: auto;
		max-width: none;
		object-fit: cover;
		mix-blend-mode: hard-light;
		pointer-events: none;
	}

	.about-hero__graphic--a {
		left: -0.5625rem;
		width: min(51.6875rem, 57vw);
		z-index: 1;
	}

	.about-hero__graphic--b {
		left: -1.125rem;
		width: min(46.5625rem, 51vw);
		z-index: 3;
	}

	.about-hero__veil {
		backdrop-filter: blur(5px);
		background: rgba(217, 217, 217, 0.01);
		opacity: 0.3;
		inset: 5.4375rem 0.875rem 1.375rem;
		z-index: 4;
	}

	.topbar,
	.about-hero__meta,
	.about-hero__copy {
		position: relative;
		z-index: 5;
	}

	.topbar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
	}

	.topbar__menu,
	.topbar__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.topbar__actions {
		justify-content: flex-end;
	}

	.topbar__brand {
		display: flex;
		justify-content: center;
	}

	.brand-mark {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 999px;
		background:
			radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.25) 28%, transparent 30%),
			conic-gradient(from 180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.35));
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.45);
	}

	.pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: 2.625rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		border: 1px solid currentColor;
		font-size: 1.125rem;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.pill--ghost {
		background: transparent;
		color: white;
	}

	.pill--ghost.is-active {
		background: white;
		color: #01a1dc;
		font-weight: 600;
	}

	.pill--solid {
		background: white;
		color: black;
		border-color: white;
	}

	.about-hero__meta {
		position: absolute;
		top: 11.5rem;
		right: clamp(2rem, 8.25vw, 7.75rem);
		width: min(20.625rem, calc(100% - (2 * var(--about-page-pad))));
		font-size: 1.25rem;
		line-height: 1.35;
		text-align: left;
	}

	.about-hero__copy {
		position: absolute;
		left: var(--page-pad);
		bottom: 3.25rem;
		max-width: 42.875rem;
	}

	.about-hero__copy h1,
	.contact h2 {
		margin: 0;
		font-size: clamp(3.5rem, 8vw, 6rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
	}

	.section-tag {
		margin: 0 0 0.875rem;
		font-size: 1.25rem;
		color: var(--muted);
	}

	.section-tag--inverse {
		color: white;
	}

	.about-intro,
	.service-overview,
	.clients,
	.team {
		padding-inline: var(--about-page-pad);
	}

	.about-intro {
		padding-top: 6rem;
		padding-bottom: 4rem;
	}

	.about-intro h2 {
		margin: 0;
		max-width: 80rem;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1.12;
		letter-spacing: -0.03em;
	}

	.about-intro__columns {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem 6rem;
		margin-top: 3rem;
	}

	.about-intro__columns p:last-child {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.35;
	}

	.service-overview,
	.clients {
		margin-top: 2rem;
		padding-top: 2rem;
		padding-bottom: 2rem;
		border-radius: 0.75rem;
	}

	.service-overview {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
		background: #ebf8fc;
		padding-block: 2rem;
	}

	.service-overview__copy h3,
	.clients__intro h3,
	.team__intro h3 {
		margin: 0;
		font-size: 2rem;
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.service-overview__copy p:last-child,
	.team__intro p,
	.team-card p,
	.contact address {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.35;
	}

	.service-overview__copy {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.service-overview__media {
		border: 1px solid #b0b0b0;
		border-radius: 0.5rem;
		overflow: clip;
		min-height: 32rem;
	}

	.service-overview__image {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.clients {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
		background: var(--paper);
		padding-block: 2rem;
	}

	.clients__intro {
		position: sticky;
		top: 6.5rem;
		align-self: start;
	}

	.clients__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0;
		align-content: start;
	}

	.clients__logo,
	.clients__more {
		border: 1px solid var(--line);
		border-radius: 0.75rem;
		min-height: 8.0625rem;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1.5rem;
		background: white;
	}

	.clients__logo img {
		max-width: 100%;
		max-height: 5rem;
		object-fit: contain;
		mix-blend-mode: multiply;
	}

	.clients__more {
		grid-column: span 3;
		justify-content: flex-start;
		font-size: 0.875rem;
		color: #666;
	}

	.team {
		padding-top: 4rem;
		padding-bottom: 4rem;
	}

	.team__intro {
		max-width: 62.5rem;
	}

	.team__gallery {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: minmax(16rem, 1fr);
		gap: 1rem;
		overflow-x: auto;
		margin: 2rem 0 1rem;
		padding-bottom: 0.5rem;
	}

	.team__gallery img {
		height: 12.5rem;
		width: 100%;
		object-fit: cover;
		border-radius: 0.5rem;
		flex-shrink: 0;
	}

	.team__cards {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	:global(.team__status) {
		grid-column: 1 / -1;
		margin: 0;
		padding: 1.25rem 1.5rem;
		border: 1px solid var(--line);
		border-radius: 0.75rem;
		background: white;
		font-size: 1rem;
		color: #4e4e4e;
	}

	:global(.team-card) {
		border: 1px solid var(--line);
		border-radius: 0.75rem;
		padding: 1.5rem;
		background: white;
		box-sizing: border-box;
	}

	:global(.team-card__media) {
		position: relative;
		width: 18rem;
		height: 22.5rem;
		max-width: 100%;
		margin-inline: auto;
		border-radius: 0.5rem;
		overflow: hidden;
		background: #d9d9d9;
	}

	:global(.team-card__photo) {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
		display: block;
	}

	:global(.team-card__photo--empty) {
		background:
			radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.5), transparent 28%),
			linear-gradient(135deg, #d9d9d9, #ececec);
	}

	:global(.team-card__body) {
		margin-top: 1rem;
	}

	:global(.team-card__role) {
		font-weight: 500;
	}

	:global(.team-card h4) {
		margin: 0;
		font-size: 1.5rem;
		line-height: 1.12;
	}

	:global(.team-card__socials),
	.footer__links,
	.footer__socials {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	:global(.team-card__socials a) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.5rem;
		height: 1.5rem;
		text-decoration: none;
		color: #1d7fc5;
	}

	:global(.team-card__socials img) {
		width: 100%;
		height: 100%;
		display: block;
	}

	.contact {
		position: relative;
		padding: 5rem var(--page-pad) 2.5rem;
		color: white;
		background: linear-gradient(122deg, #01a1dc 0%, #1952d2 100%);
		overflow: clip;
	}

	.contact__shape {
		position: absolute;
		inset: -6rem auto auto 50%;
		width: min(120rem, 140vw);
		max-width: none;
		transform: translateX(-8%) rotate(90deg);
		opacity: 0.8;
	}

	.contact__inner,
	.footer {
		position: relative;
		z-index: 1;
	}

	.contact__inner {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
		align-items: center;
	}

	.contact__copy {
		max-width: 39.25rem;
	}

	.contact address {
		margin-top: 10rem;
		max-width: 20.625rem;
		color: white;
		font-style: normal;
	}

	.contact__form {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.75rem;
	}

	.contact__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		width: 100%;
	}

	.contact label {
		width: 100%;
	}

	.contact input,
	.contact textarea {
		width: 100%;
		box-sizing: border-box;
		padding: 1.5rem 1.25rem;
