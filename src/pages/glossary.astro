---
import Layout from '../layouts/Layout.astro';

const heroShape = '/figma/legal-glossary-hero-wave.svg';
const footerShape = '/figma/glossary-contact-shape.svg';

const introParagraphs = [
	'Metocean glossary is a dictionary that is authoritative reference to hydrographic related terms and definitions used in various standards, specifications and other informative referred in Maritime Industry.',
	'In Indonesian hydrography, The International Hydrographics Dictionary (S-32) is the main standards of terms and definition used.',
	'Use the relevance 2-3 words from the desired term to get the best result from our search feature. Example: to find HAT refering to Tidal Level, please type "HAT Tidal Level" in the search box.',
];

const glossaryRows = [
	{
		no: '1',
		term: 'Point',
		description: 'One thirty-second of a circle, that is 11 15\', reckoned clockwise from north at the horizon.',
	},
	{
		no: '2',
		term: 'Time',
		description: 'The measurable aspect of duration. It may be expressed in relation to a reference phenomenon.',
	},
	{
		no: '3',
		term: 'Ice',
		description: 'The solid form of water.',
	},
	{
		no: '4',
		term: 'Ria',
		description: 'A long narrow inlet with depth gradually diminishing inward.',
	},
	{
		no: '5',
		term: 'Surf',
		description: 'Collective term for breakers, bores, swash and backwash on a shore.',
	},
	{
		no: '6',
		term: 'Gat',
		description: 'A natural or artificial passage or small channel through shoals, breakers, coral or mangrove areas, among banks or islands, or from lagoons or estuaries through a barrier beach.',
	},
	{
		no: '7',
		term: 'Wave',
		description: 'A disturbance which moves through or over the surface of a medium with accompanying propagation of energy.',
	},
	{
		no: '8',
		term: 'Light',
		description: 'A luminous or lighted aid to navigation; a distinctive indication of a danger.',
	},
	{
		no: '9',
		term: 'Earth',
		description: 'The planet which we inhabit, third in distance from the Sun.',
	},
	{
		no: '10',
		term: 'Area',
		description: 'In United Nations law of the sea terminology, the sea-bed and ocean floor and subsoil thereof, beyond the limits of national jurisdiction.',
	},
];
---

<Layout title="Metocean Glossary | Bhumi Warih" footerShape={footerShape} footerGlossaryHref="/glossary">
	<main class="glossary-page">
		<section class="glossary-hero">
			<div class="glossary-hero__bg"></div>
			<div class="glossary-hero__shape-wrap" aria-hidden="true">
				<img class="glossary-hero__shape" src={heroShape} alt="" />
			</div>
			<div class="glossary-hero__copy">
				<p class="glossary-hero__eyebrow">/Glossary</p>
				<h1>Metocean Glossary</h1>
			</div>
		</section>

		<section class="glossary-content">
			<div class="glossary-content__intro">
				<h2>A trusted hydrography reference for the maritime industry.</h2>
				{
					introParagraphs.map((paragraph) => <p>{paragraph}</p>)
				}
			</div>

			<section class="glossary-card" aria-labelledby="glossary-table-heading">
				<div class="glossary-card__toolbar">
					<label class="select-field">
						<span>Menampilkan</span>
						<select aria-label="Entries per page">
							<option selected>20</option>
						</select>
					</label>

					<label class="search-field">
						<span class="sr-only">Search glossary</span>
						<input type="search" placeholder="Cari Istilah" />
						<span class="search-field__icon" aria-hidden="true"></span>
					</label>
				</div>

				<div class="glossary-table-wrap">
					<table class="glossary-table">
						<caption id="glossary-table-heading" class="sr-only">Glossary terms</caption>
						<thead>
							<tr>
								<th scope="col">No.</th>
								<th scope="col">Term</th>
								<th scope="col">Description</th>
							</tr>
						</thead>
						<tbody>
							{
								glossaryRows.map((row) => (
									<tr>
										<td>{row.no}</td>
										<td>{row.term}</td>
										<td>{row.description}</td>
									</tr>
								))
							}
						</tbody>
					</table>
				</div>

				<div class="glossary-card__footer">
					<p>Menampilkan 1 to 10 of 6,500 entries</p>
					<nav class="pagination" aria-label="Glossary pages">
						<a href="#glossary-table-heading" class="pagination__arrow" aria-label="Previous page">‹</a>
						<a href="#glossary-table-heading" class="pagination__page is-active" aria-current="page">1</a>
						<a href="#glossary-table-heading" class="pagination__page">2</a>
						<a href="#glossary-table-heading" class="pagination__page">3</a>
						<a href="#glossary-table-heading" class="pagination__page">4</a>
						<span class="pagination__page pagination__page--ellipsis">…</span>
						<a href="#glossary-table-heading" class="pagination__page">650</a>
						<a href="#glossary-table-heading" class="pagination__arrow" aria-label="Next page">›</a>
					</nav>
				</div>
			</section>
		</section>
	</main>
</Layout>

<style>
	:global(:root) {
		--page-pad: clamp(1rem, 4vw, 5rem);
		--glossary-blue: #004991;
		--glossary-accent: #00a1dc;
		--glossary-line: #d6dce6;
		--glossary-paper: #f6f7f9;
		--glossary-text: #0f1723;
		--glossary-muted: #556274;
	}

	.glossary-page {
		background: white;
		color: var(--glossary-text);
	}

	.glossary-hero {
		position: relative;
		min-height: 27rem;
		overflow: clip;
		color: white;
	}

	.glossary-hero__bg {
		position: absolute;
		inset: 0;
		background: var(--glossary-blue);
	}

	.glossary-hero__shape-wrap {
		position: absolute;
		inset: 0 auto 0 0;
		width: min(56rem, 88vw);
		overflow: hidden;
	}

	.glossary-hero__shape {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: auto;
		max-width: none;
		opacity: 0.95;
	}

	.glossary-hero__copy {
		position: relative;
		z-index: 1;
		padding: 9rem var(--page-pad) 3.5rem;
		max-width: 52rem;
	}

	.glossary-hero__eyebrow {
		margin: 0 0 1rem;
		font-size: clamp(1.4rem, 2vw, 2rem);
		line-height: 1.1;
	}

	.glossary-hero h1 {
		margin: 0;
		font-size: clamp(3.5rem, 7vw, 6rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
	}

	.glossary-content {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.25fr);
		gap: clamp(2rem, 4vw, 4rem);
		padding: 4rem var(--page-pad) 5rem;
		align-items: start;
	}

	.glossary-content__intro {
		max-width: 28rem;
	}

	.glossary-content__intro h2 {
		margin: 0 0 1.5rem;
		font-size: clamp(1.9rem, 3vw, 2.875rem);
		line-height: 1;
		letter-spacing: -0.04em;
	}

	.glossary-content__intro p {
		margin: 0 0 1.25rem;
		font-size: 1rem;
		line-height: 1.5;
		color: var(--glossary-muted);
	}

	.glossary-card {
		padding: 1.5rem;
		border: 1px solid var(--glossary-line);
		border-radius: 2rem;
		background: white;
		box-shadow: 0 1.25rem 3.5rem rgba(9, 39, 76, 0.08);
	}

	.glossary-card__toolbar,
	.glossary-card__footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.glossary-card__toolbar {
		margin-bottom: 1.25rem;
	}

	.select-field {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.95rem;
		color: var(--glossary-muted);
	}

	.select-field select,
	.search-field input {
		appearance: none;
		border: 1px solid var(--glossary-line);
		border-radius: 999px;
		background: var(--glossary-paper);
		font: inherit;
		color: var(--glossary-text);
	}

	.select-field select {
		min-width: 4.5rem;
		padding: 0.85rem 2.25rem 0.85rem 1rem;
		background-image:
			linear-gradient(45deg, transparent 50%, var(--glossary-accent) 50%),
			linear-gradient(135deg, var(--glossary-accent) 50%, transparent 50%);
		background-position:
			calc(100% - 1.15rem) 50%,
			calc(100% - 0.8rem) 50%;
		background-size: 0.4rem 0.4rem, 0.4rem 0.4rem;
		background-repeat: no-repeat;
	}

	.search-field {
		position: relative;
		display: block;
		flex: 0 1 20rem;
	}

	.search-field input {
		width: 100%;
		padding: 0.95rem 3rem 0.95rem 1rem;
	}

	.search-field__icon {
		position: absolute;
		top: 50%;
		right: 1rem;
		width: 1rem;
		height: 1rem;
		border: 2px solid var(--glossary-accent);
		border-radius: 999px;
		transform: translateY(-55%);
	}

	.search-field__icon::after {
		content: '';
		position: absolute;
		right: -0.35rem;
		bottom: -0.35rem;
		width: 0.5rem;
		height: 2px;
		background: var(--glossary-accent);
		transform: rotate(45deg);
		transform-origin: center;
	}

	.glossary-table-wrap {
		overflow-x: auto;
		border: 1px solid var(--glossary-line);
		border-radius: 1.5rem;
	}

	.glossary-table {
		width: 100%;
		border-collapse: collapse;
		min-width: 42rem;
	}

	.glossary-table th,
	.glossary-table td {
		padding: 1rem 1.1rem;
		text-align: left;
		vertical-align: top;
		border-bottom: 1px solid var(--glossary-line);
		font-size: 0.95rem;
		line-height: 1.45;
	}

	.glossary-table thead th {
		background: #eff5fb;
		color: var(--glossary-blue);
		font-weight: 600;
	}

	.glossary-table tbody tr:nth-child(even) td {
		background: #fbfcfe;
	}

	.glossary-table tbody tr:last-child td {
		border-bottom: 0;
	}

	.glossary-table th:first-child,
	.glossary-table td:first-child {
		width: 4.75rem;
	}

	.glossary-table th:nth-child(2),
	.glossary-table td:nth-child(2) {
		width: 9rem;
		font-weight: 600;
	}

	.glossary-card__footer {
		margin-top: 1.25rem;
		font-size: 0.95rem;
		color: var(--glossary-muted);
	}

	.glossary-card__footer p {
		margin: 0;
	}

	.pagination {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.pagination a,
	.pagination span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.25rem;
		height: 2.25rem;
		padding: 0 0.4rem;
		border-radius: 999px;
		text-decoration: none;
		color: inherit;
	}

	.pagination__arrow,
	.pagination__page {
		border: 1px solid var(--glossary-line);
		background: white;
	}

	.pagination__page.is-active {
		border-color: var(--glossary-accent);
		background: var(--glossary-accent);
		color: white;
	}

	.pagination__page--ellipsis {
		border-color: transparent;
		background: transparent;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 64rem) {
		.glossary-content {
			grid-template-columns: 1fr;
		}

		.glossary-content__intro {
			max-width: none;
		}
	}

	@media (max-width: 48rem) {
		.glossary-hero {
			min-height: 22rem;
		}

		.glossary-hero__shape-wrap {
			width: 100vw;
		}

		.glossary-hero__copy {
			padding-top: 7rem;
		}

		.glossary-card {
			padding: 1rem;
			border-radius: 1.5rem;
		}

		.glossary-card__toolbar,
		.glossary-card__footer {
			flex-direction: column;
			align-items: stretch;
		}

		.search-field {
			flex-basis: auto;
		}

		.pagination {
			justify-content: flex-start;
		}
	}
</style>
