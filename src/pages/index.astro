---
import Layout from '../layouts/Layout.astro';

const heroImage = '/figma/home-hero-bg.png';
const rigImage = '/figma/home-hero-rig.png';
const serviceOrbitImage = '/figma/service-metocean-card.png';
const serviceMapImage = '/figma/service-dss-card.png';
const serviceWaveImage = '/figma/service-extended-card.png';
const industryOilImage = '/figma/home-industry-oil.png';
const industryPortImage = '/figma/home-industry-port.png';
const industryOtherImage = '/figma/home-industry-other.png';
const industryIconOilBase = '/figma/industry-icon-oil-base.png';
const industryIconOilOverlay = '/figma/industry-icon-oil-overlay.png';
const industryIconPortBase = '/figma/industry-icon-port-base.png';
const industryIconOtherOverlay = '/figma/industry-icon-other-overlay.png';
const industryListItemIcon = '/figma/industry-list-item-icon.svg';
const iconDroplet = '/figma/icon-droplet.svg';
const iconEarth = '/figma/icon-earth.svg';
const iconPeople = '/figma/icon-people.svg';
const blogCardA = '/figma/blog-card-a.png';
const blogCardB = '/figma/blog-card-b.png';
const blogCardC = '/figma/blog-card-c.png';

const services = [
	{
		title: 'Metocean Design Criteria',
		description: 'Extreme Value Analysis. Numerical Simulation. Ocean, Climate and Weather Analysis',
		icon: iconEarth,
		image: serviceOrbitImage,
		tone: 'light-blue',
	},
	{
		title: 'Marine Operation Decision Support System (MO-DSS)',
		description: 'Marine Sea State Prediction. Weather Forecast. Tow Route Forecast. Weather Window.',
		icon: iconDroplet,
		image: serviceMapImage,
		tone: 'mist',
	},
	{
		title: 'Extended Services',
		description: 'Our team can provide customized services tailored for your specific needs in maritime industry.',
		icon: iconPeople,
		image: serviceWaveImage,
		tone: 'white',
	},
];

const industries = [
	{
		eyebrow: 'Oil & Gas',
		copy:
			'Assist with the necessary information on atmospheric and oceanographic conditions on our client working sites. Metocean data and analysis will enable our clients’ engineers to refine plans with better cost conformity.',
		image: industryOilImage,
		accent: '#cfd8ee',
		iconLayers: [industryIconOilBase, industryIconOilOverlay],
		items: [
			'Marine Sea State Prediction',
			'Metocean Study',
			'Pipeline Planning and Routing',
			'Weather Window',
			'Oil Spill Modelling',
		],
	},
	{
		eyebrow: 'Port and Harbor',
		copy:
			'Develop an optimized port and harbor design that meets economic and technical viability criteria including design protection, engineering efficiency, and maintainability.',
		image: industryPortImage,
		accent: '#ffffff',
		iconLayers: [industryIconPortBase],
		items: [
			'Navigation Safety',
			'Marine numerical simulation',
			'Environmental study at port and harbour area',
			'Marine sea state prediction',
		],
	},
	{
		eyebrow: 'Other Maritime Industry',
		copy:
			'Bring clarity to any maritime industry problem at any stage. Before planning any maritime development, we need to understand the natural environment surrounding the project location.',
		image: industryOtherImage,
		accent: '#e7ecec',
		iconLayers: [industryIconPortBase, industryIconOtherOverlay],
		items: [
			'Environmental impact assessments (EIA)',
			'Field observation',
			'Simulation and modelling',
			'Geographical information system (GIS)',
			'Meteorological and oceanographic study',
		],
	},
];

const blogPosts = [
	{
		tag: 'Products',
		title: 'Get To Know the Metocean Study, Assess Extreme Weather Risk for Your Project',
		excerpt:
			'Metocean is concerned with understanding meteorological and oceanographic conditions at an engineering or renewable energy project site.',
		image: blogCardA,
	},
	{
		tag: 'Projects',
		title: 'Smarter Land Decisions Start Here: Discover the Power of Land Forecasting',
		excerpt:
			'In dynamic and weather-sensitive sectors such as maritime operations, energy production, and resource exploration, atmospheric conditions matter.',
		image: blogCardB,
	},
	{
		tag: 'Projects',
		title: 'Navigating Disaster Resilience: Flood and Tsunami Early Warning System',
		excerpt:
			'PT Bhumi Warih Geohydromatics supported the development of an Early Warning System platform for floods and tsunamis in the Palu region.',
		image: blogCardC,
	},
	{
		tag: 'Science and Technology',
		title: 'The Future is Bright: Unlocking Indonesia’s Solar Potential',
		excerpt:
			'Geospatial analysis and financial modelling have identified hundreds of viable renewable project locations across Indonesia.',
		image: blogCardA,
	},
];

const [metoceanService, dssService, extendedService] = services;
---

<Layout title="Bhumi Warih">
	<main class="page-shell">
		<section class="hero" id="home">
			<div class="hero__backdrop">
				<img src={heroImage} alt="" loading="eager" fetchpriority="high" />
			</div>

			<div class="hero__meta">Registered on CIVD System: SPDA Number 73970/EMP/2024</div>
			<h1 class="hero__wordmark">BHUMI WARIH</h1>
			<div class="hero__rig">
				<img src={rigImage} alt="Offshore platform" />
			</div>

			<div class="hero__content">
				<p class="hero__headline">Meteorological &amp; Oceanographic Analysis to Connected Intelligence</p>
				<a href="/glossary" class="pill pill--ghost hero__glossary">Glossary</a>
			</div>
		</section>

		<section class="about-gap" id="about" aria-label="About Bhumi Warih">
			<div class="about-gap__copy" data-reveal-root>
				<div class="about-gap__intro">
					<p class="section-tag about-gap__tag" data-reveal data-reveal-delay="0">About</p>
					<p class="about-gap__lead" data-reveal data-reveal-delay="120">
						Bhumi Warih is an Indonesian based company specializing in meteorological and
						oceanographic (Metocean) analysis.
					</p>
				</div>

				<div class="about-gap__aside">
					<p class="about-gap__body" data-reveal data-reveal-delay="240">
						Our knowledge and experience have been acquired from specialized services in the
						maritime industry since 2010, with strong access and local understanding across
						South East Asia.
					</p>
					<a class="pill pill--outline-dark about-gap__cta" href="/about">About Us</a>
				</div>
			</div>
		</section>

		<section class="services section" id="service">
			<div class="section__intro">
				<div>
					<p class="section-tag">Services</p>
					<h2>Offshore and Coastal Navigation Decision Making</h2>
				</div>
				<p>
					Make informed decisions through accurate analysis and expert guidance, for safer
					operations, optimized performance, and cost-efficient protection of marine assets.
				</p>
			</div>

			<div class="service-grid">
				<div class="service-grid__stack">
					<article class={`service-card service-card--stacked service-card--metocean service-card--${metoceanService.tone}`}>
						<div class="service-card__copy">
							<img class="service-card__icon" src={metoceanService.icon} alt="" />
							<h3>{metoceanService.title}</h3>
							<p>{metoceanService.description}</p>
							<a href="#contact" class="pill pill--outline-dark">Read More <span aria-hidden="true">→</span></a>
						</div>
						<div class="service-card__media">
							<img src={metoceanService.image} alt="" />
						</div>
					</article>

					<article class={`service-card service-card--stacked service-card--extended service-card--${extendedService.tone}`}>
						<div class="service-card__copy">
							<img class="service-card__icon" src={extendedService.icon} alt="" />
							<h3>{extendedService.title}</h3>
							<p>{extendedService.description}</p>
							<a href="#contact" class="pill pill--outline-dark">Read More <span aria-hidden="true">→</span></a>
						</div>
						<div class="service-card__media">
							<img src={extendedService.image} alt="" />
						</div>
					</article>
				</div>

				<article class={`service-card service-card--feature service-card--dss service-card--${dssService.tone}`}>
					<div class="service-card__copy">
						<img class="service-card__icon" src={dssService.icon} alt="" />
						<h3>{dssService.title}</h3>
						<p>{dssService.description}</p>
						<a href="#contact" class="pill pill--outline-dark">Read More <span aria-hidden="true">→</span></a>
					</div>
					<div class="service-card__media">
						<img src={dssService.image} alt="" />
					</div>
				</article>
			</div>
		</section>

		<section class="approach section">
			<p class="section-tag section-tag--center">Approach</p>
			<h2>Integrated Marine Intelligence &amp; Business Insight Ecosystem</h2>
			<p>
				The collaboration between oceanographic science, geospatial engineering, and GeoAI
				platforms enhances research capabilities, R&amp;D, and predictive models for national
				maritime disasters and climate.
			</p>
		</section>

		<section class="industries section" id="industry">
			<div class="section__intro">
				<div>
					<p class="section-tag">Industries</p>
					<h2>Bringing Clarity Across Industries</h2>
				</div>
				<p>
					Assess and align the critical elements needed in various maritime industry. Our team
					possesses a strong knowledge of South East Asian waters that brings clarity to any
					maritime industry’s problem at any stage of development.
				</p>
			</div>

			<div class="industry-stack-shell">
				<div class="industry-stack">
					{
						industries.map((industry, index) => (
							<article class="industry-card" style={`--industry-index:${index}; --panel-accent:${industry.accent}`}>
								<div class="industry-card__summary">
									<h3>{industry.eyebrow}</h3>
									<div class="industry-card__icon" aria-hidden="true">
										{
											industry.iconLayers.map((icon) => (
												<img src={icon} alt="" />
											))
										}
									</div>
									<ul>
										{
											industry.items.map((item) => (
												<li>
													<span>{item}</span>
													<img src={industryListItemIcon} alt="" aria-hidden="true" />
												</li>
											))
										}
									</ul>
								</div>
								<div class="industry-card__detail">
									<div class="industry-card__image">
										<img src={industry.image} alt="" />
									</div>
									<div class="industry-card__body">
										<p>{industry.copy}</p>
										<a href="#contact" class="pill pill--blue">Read More <span aria-hidden="true">→</span></a>
									</div>
								</div>
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="blog section" id="blog">
			<div class="section__intro">
				<div>
					<p class="section-tag">Blog</p>
					<h2>Insights &amp; Updates</h2>
				</div>
				<p>Our freshest thoughts on the latest trends, ongoing work, and what is coming next.</p>
			</div>

			<div class="blog-grid">
				{
					blogPosts.map((post) => (
						<article class="blog-card" style={`background-image:linear-gradient(180deg, rgba(10,40,75,0.08) 0%, rgba(9,17,28,0.8) 74%), url(${post.image})`}>
							<div class="blog-card__tag">{post.tag}</div>
							<div class="blog-card__content">
								<h3>{post.title}</h3>
								<p>{post.excerpt}</p>
								<a href="#contact" class="pill pill--ghost">Read More <span aria-hidden="true">→</span></a>
							</div>
						</article>
					))
				}
			</div>
		</section>

	</main>
</Layout>

<script is:inline>
	const aboutRevealRoots = document.querySelectorAll('[data-reveal-root]');
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (prefersReducedMotion) {
		for (const root of aboutRevealRoots) {
			root.classList.add('is-visible');
		}
	} else if ('IntersectionObserver' in window) {
		const revealObserver = new IntersectionObserver(
			(entries, observer) => {
				for (const entry of entries) {
					if (!entry.isIntersecting) continue;
					entry.target.classList.add('is-visible');
					observer.unobserve(entry.target);
				}
			},
			{
				threshold: 0.28,
				rootMargin: '0px 0px -8% 0px',
			}
		);

		for (const root of aboutRevealRoots) {
			revealObserver.observe(root);
		}
	} else {
		for (const root of aboutRevealRoots) {
			root.classList.add('is-visible');
		}
	}
</script>

<style>
	:global(:root) {
		--bg: #f0ecea;
		--surface: #f3f3f3;
		--ink: #121212;
		--muted: #5b5b5b;
		--line: #b7b7b7;
		--blue: #00a1dc;
		--deep-blue: #1952d2;
		--white-12: rgba(255, 255, 255, 0.12);
		--radius-xl: 1rem;
		--radius-2xl: 1.5rem;
		--page-pad: clamp(1rem, 4vw, 5rem);
		--service-gap: 1.875rem;
	}

	.page-shell {
		background: var(--bg);
		color: var(--ink);
	}

	.section,
	.about-gap {
		padding-inline: var(--page-pad);
	}

	.hero {
		position: relative;
		min-height: 56.25rem;
		padding: 6.5rem var(--page-pad) 3.5rem;
		overflow: clip;
		color: white;
		background: linear-gradient(180deg, rgba(0, 41, 107, 0.18), rgba(0, 18, 48, 0.18));
	}

	.hero__backdrop,
	.hero__backdrop img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.hero__backdrop img {
		object-fit: cover;
	}

	.hero__backdrop::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, rgba(24, 83, 211, 0.28) 0%, rgba(24, 83, 211, 0.1) 44%, rgba(12, 54, 129, 0.34) 100%),
			linear-gradient(180deg, rgba(255, 255, 255, 0) 62%, rgba(0, 0, 0, 0.06) 100%);
	}

	.topbar,
	.hero__meta,
	.hero__wordmark,
	.hero__rig,
	.hero__content {
		position: relative;
		z-index: 1;
	}

	.topbar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
	}

	.topbar__menu,
	.topbar__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.topbar__actions {
		justify-content: flex-end;
	}

	.topbar__brand {
		display: flex;
		justify-content: center;
	}

	.brand-mark {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 999px;
		background:
			radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.25) 28%, transparent 30%),
			conic-gradient(from 180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.35));
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.45);
	}

	.pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: 2.625rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		border: 1px solid currentColor;
		font-size: 1.125rem;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.pill--ghost {
		color: white;
		background: transparent;
	}

	.pill--solid {
		color: black;
		background: white;
		border-color: white;
	}

	.pill--outline-dark {
		color: var(--ink);
		border-color: var(--ink);
		background: transparent;
	}

	.pill--blue {
		color: white;
		background: #08a9d9;
		border-color: #08a9d9;
	}

	.hero__meta {
		margin-top: 3.75rem;
		margin-left: auto;
		max-width: 20.625rem;
		font-size: 0.9375rem;
		line-height: 1.6;
		text-align: right;
	}

	.hero__wordmark {
		margin: 8rem 0 0;
		font-size: clamp(4.2rem, 14vw, 12.75rem);
		line-height: 0.92;
		letter-spacing: -0.05em;
	}

	.hero__rig {
		position: absolute;
		right: 7.25rem;
		top: 8rem;
		width: min(61.3vw, 55.125rem);
	}

	.hero__rig img {
		display: block;
		width: 100%;
		height: auto;
	}

	.hero__content {
		margin-top: 6rem;
		width: 100%;
		max-width: none;
		display: grid;
		grid-template-columns: minmax(0, 42.875rem) auto;
		align-items: flex-end;
		gap: 1.5rem;
	}

	.hero__headline {
		max-width: 42.875rem;
		margin: 0;
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.hero__glossary {
		justify-self: end;
		align-self: end;
	}

	.about-gap {
		min-height: 40rem;
		padding-top: 3.1875rem;
		padding-bottom: 3.5rem;
		display: grid;
		align-content: start;
	}

	.about-gap__copy {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 6.5rem;
		align-items: start;
	}

	.about-gap__intro {
		max-width: 39.25rem;
	}

	.about-gap__tag {
		margin-bottom: 1.25rem;
	}

	.about-gap__lead,
	.about-gap__body {
		margin: 0;
		font-size: 2rem;
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.about-gap__aside {
		padding-top: 12.5rem;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 5.25rem;
	}

	.about-gap__body {
		max-width: 39.25rem;
	}

	.about-gap__cta {
		color: #1e1e1e;
	}

	[data-reveal-root] [data-reveal] {
		opacity: 0;
		transform: translate3d(0, 2rem, 0);
		transition:
			opacity 1100ms cubic-bezier(0.22, 1, 0.36, 1),
			transform 1100ms cubic-bezier(0.22, 1, 0.36, 1);
		transition-delay: var(--reveal-delay, 0ms);
		will-change: opacity, transform;
	}

	[data-reveal-root] [data-reveal-delay='0'] {
		--reveal-delay: 0ms;
	}

	[data-reveal-root] [data-reveal-delay='120'] {
		--reveal-delay: 120ms;
	}

	[data-reveal-root] [data-reveal-delay='240'] {
		--reveal-delay: 240ms;
	}

	[data-reveal-root].is-visible [data-reveal] {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	.section {
		padding-top: 5rem;
		padding-bottom: 5rem;
	}

	.section-tag {
		margin: 0 0 0.75rem;
		font-size: 1.25rem;
		color: var(--blue);
	}

	.section-tag--center {
		text-align: center;
	}

	.section-tag--inverse {
		color: rgba(255, 255, 255, 0.76);
	}

	.section__intro,
	.approach {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem 2rem;
		align-items: end;
	}

	.section__intro h2,
	.approach h2,
	.contact h2 {
		margin: 0;
		font-size: clamp(2.5rem, 4vw, 3.5rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.section__intro p:last-child,
	.approach > p:last-child {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.35;
		color: var(--muted);
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: var(--service-gap);
		margin-top: 1.5rem;
		align-items: stretch;
	}

	.service-grid__stack {
		display: grid;
		grid-template-columns: 1fr;
		grid-template-rows: repeat(2, minmax(0, 1fr));
		gap: var(--service-gap);
	}

	.service-card {
		display: grid;
		grid-template-columns: minmax(16rem, 1fr) minmax(16rem, 1fr);
		min-height: 22.8125rem;
		border: 1px solid var(--line);
		border-radius: 0.75rem;
		overflow: clip;
		background: white;
	}

	.service-card--feature {
		min-height: 47.5rem;
	}

	.service-card--feature .service-card__copy {
		padding-bottom: 2rem;
	}

	.service-card--feature .service-card__media img {
		object-position: center bottom;
	}

	.service-card--dss {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		background: #e6e7ea;
	}

	.service-card--dss .service-card__copy {
		width: 100%;
		padding: 1.5rem;
		background: transparent;
		gap: 0.8125rem;
	}

	.service-card--dss .service-card__copy h3 {
		max-width: 100%;
		font-size: 2.25rem;
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.service-card--dss .service-card__copy p {
		max-width: 100%;
		font-size: 1.25rem;
		line-height: 1.2;
	}

	.service-card--dss .service-card__copy .pill {
		margin-top: 0;
	}

	.service-card--dss .service-card__media {
		height: 27.1875rem;
		background: transparent;
		overflow: hidden;
	}

	.service-card--dss .service-card__media img {
		position: absolute;
		left: 0;
		top: 0.5625rem;
		width: 28.9375rem;
		height: auto;
		max-width: none;
		object-fit: contain;
		mix-blend-mode: multiply;
	}

	.service-card--light-blue .service-card__copy {
		background: #dbe5f7;
	}

	.service-card--mist .service-card__copy {
		background: #e6e7ea;
	}

	.service-card--white .service-card__copy {
		background: white;
	}

	.service-card__copy {
		padding: var(--service-gap);
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1rem;
	}

	.service-card__icon {
		width: 3rem;
		height: 3rem;
	}

	.service-card__copy h3 {
		margin: 0;
		font-size: 2.25rem;
