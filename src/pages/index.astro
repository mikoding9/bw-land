---
import { Image } from "astro:assets";
import BlogSection from "../components/BlogSection.astro";
import Layout from "../layouts/Layout.astro";
import ServicesSection from "../components/ServicesSection.astro";
import { blogPostSummaries } from "../data/blog";
import { services } from "../data/services";
import heroBackdropImage from "../assets/home/hero-bg.png";
import heroRigImage from "../assets/home/hero-rig.png";
import industryOilCardImage from "../assets/home/industry-oil.png";
import industryPortCardImage from "../assets/home/industry-port.png";
import industryOtherCardImage from "../assets/home/industry-other.png";

const industryIconOilBase = "/figma/industry-icon-oil-base.png";
const industryIconOilOverlay = "/figma/industry-icon-oil-overlay.png";
const industryIconPortBase = "/figma/industry-icon-port-base.png";
const industryIconOtherOverlay = "/figma/industry-icon-other-overlay.png";
const industryListItemIcon = "/figma/industry-list-item-icon.svg";
const industries = [
    {
        eyebrow: "Oil & Gas",
        slug: "metocean",
        copy: "Assist with the necessary information on atmospheric and oceanographic conditions on our client working sites. Metocean data and analysis will enable our clients’ engineers to refine plans with better cost conformity.",
        image: industryOilCardImage,
        accent: "#cfd8ee",
        iconLayers: [industryIconOilBase, industryIconOilOverlay],
        items: [
            "Marine Sea State Prediction",
            "Metocean Study",
            "Pipeline Planning and Routing",
            "Weather Window",
            "Oil Spill Modelling",
        ],
    },
    {
        eyebrow: "Port and Harbor",
        slug: "dss",
        copy: "Develop an optimized port and harbor design that meets economic and technical viability criteria including design protection, engineering efficiency, and maintainability.",
        image: industryPortCardImage,
        accent: "#ffffff",
        iconLayers: [industryIconPortBase],
        items: [
            "Navigation Safety",
            "Marine numerical simulation",
            "Environmental study at port and harbour area",
            "Marine sea state prediction",
        ],
    },
    {
        eyebrow: "Other Maritime Industry",
        slug: "extended",
        copy: "Bring clarity to any maritime industry problem at any stage. Before planning any maritime development, we need to understand the natural environment surrounding the project location.",
        image: industryOtherCardImage,
        accent: "#e7ecec",
        iconLayers: [industryIconPortBase, industryIconOtherOverlay],
        items: [
            "Environmental impact assessments (EIA)",
            "Field observation",
            "Simulation and modelling",
            "Geographical information system (GIS)",
            "Meteorological and oceanographic study",
        ],
    },
];

const blogPosts = blogPostSummaries.map((post) => ({
    ...post,
    href: `/insight/${post.slug}`,
}));
---

<Layout title="Bhumi Warih">
    <main class="page-shell">
        <section class="hero" id="home" data-nav-hero>
            <div class="hero__backdrop">
                <Image
                    class="hero__backdrop-image"
                    src={heroBackdropImage}
                    alt=""
                    loading="eager"
                    fetchpriority="high"
                    quality={80}
                />
            </div>

            <div class="hero__meta">
                Registered on CIVD System: SPDA Number 73970/EMP/2024
            </div>
            <h1 class="hero__wordmark">BHUMI WARIH</h1>
            <div class="hero__rig">
                <Image
                    class="hero__rig-image"
                    src={heroRigImage}
                    alt="Offshore platform"
                    loading="eager"
                    fetchpriority="high"
                    quality={80}
                />
            </div>

            <div class="hero__content">
                <p class="hero__headline">
                    Meteorological &amp;
                    <br />
                    Oceanographic Analysis
                    <br />
                    to Connected Intelligence
                </p>
                <a href="/glossary" class="pill pill--ghost hero__glossary"
                    >Glossary</a
                >
            </div>
        </section>

        <section class="about-gap" id="about" aria-label="About Bhumi Warih">
            <div class="about-gap__copy" data-reveal-root>
                <div class="about-gap__intro">
                    <p
                        class="section-tag about-gap__tag"
                        data-reveal
                        data-reveal-delay="0"
                    >
                        About
                    </p>
                    <p
                        class="about-gap__lead"
                        data-reveal
                        data-reveal-delay="120"
                    >
                        Bhumi Warih is an Indonesian based company specializing
                        in meteorological and oceanographic (Metocean) analysis.
                    </p>
                </div>

                <div class="about-gap__aside">
                    <p
                        class="about-gap__body"
                        data-reveal
                        data-reveal-delay="240"
                    >
                        Our knowledge and experience have been acquired from
                        specialized services in the maritime industry since
                        2010, with strong access and local understanding across
                        South East Asia.
                    </p>
                    <a
                        class="pill pill--outline-dark about-gap__cta"
                        href="/about">About Us</a
                    >
                </div>
            </div>
        </section>

        <ServicesSection services={services} />

        <section class="approach section">
            <p class="section-tag section-tag--center">Approach</p>
            <h2>
                Integrated Marine Intelligence &amp; Business Insight Ecosystem
            </h2>
            <p>
                The collaboration between oceanographic science, geospatial
                engineering, and GeoAI platforms enhances research capabilities,
                R&amp;D, and predictive models for national maritime disasters
                and climate.
            </p>
        </section>

        <section class="industries section" id="industry">
            <div class="section__intro">
                <div>
                    <p class="section-tag">Industries</p>
                    <h2>Bringing Clarity Across Industries</h2>
                </div>
                <p>
                    Assess and align the critical elements needed in various
                    maritime industry. Our team possesses a strong knowledge of
                    South East Asian waters that brings clarity to any maritime
                    industry’s problem at any stage of development.
                </p>
            </div>

            <div class="industry-stack-shell">
                <div class="industry-stack">
                    {
                        industries.map((industry, index) => (
                            <article
                                class="industry-card"
                                style={`--industry-index:${index}; --panel-accent:${industry.accent}`}
                            >
                                <div class="industry-card__summary">
                                    <h3>{industry.eyebrow}</h3>
                                    <div
                                        class="industry-card__icon"
                                        aria-hidden="true"
                                    >
                                        {industry.iconLayers.map((icon) => (
                                            <img src={icon} alt="" />
                                        ))}
                                    </div>
                                    <ul>
                                        {industry.items.map((item) => (
                                            <li>
                                                <span>{item}</span>
                                                <img
                                                    src={industryListItemIcon}
                                                    alt=""
                                                    aria-hidden="true"
                                                />
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                                <div class="industry-card__detail">
                                    <div class="industry-card__image">
                                        <Image
                                            class="industry-card__img"
                                            src={industry.image}
                                            alt={industry.eyebrow}
                                            loading="lazy"
                                            quality={78}
                                        />
                                    </div>
                                    <div class="industry-card__body">
                                        <p>{industry.copy}</p>
                                        <a
                                            href={`/service/${industry.slug}`}
                                            class="pill pill--blue"
                                        >
                                            Read More{" "}
                                            <span aria-hidden="true">→</span>
                                        </a>
                                    </div>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <BlogSection posts={blogPosts} />
    </main>
</Layout>

<script is:inline>
    const aboutRevealRoots = document.querySelectorAll("[data-reveal-root]");
    const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    ).matches;

    if (prefersReducedMotion) {
        for (const root of aboutRevealRoots) {
            root.classList.add("is-visible");
        }
    } else if ("IntersectionObserver" in window) {
        const revealObserver = new IntersectionObserver(
            (entries, observer) => {
                for (const entry of entries) {
                    if (!entry.isIntersecting) continue;
                    entry.target.classList.add("is-visible");
                    observer.unobserve(entry.target);
                }
            },
            {
                threshold: 0.28,
                rootMargin: "0px 0px -8% 0px",
            },
        );

        for (const root of aboutRevealRoots) {
            revealObserver.observe(root);
        }
    } else {
        for (const root of aboutRevealRoots) {
            root.classList.add("is-visible");
        }
    }
</script>

<style>
    :global(:root) {
        --bg: #f0ecea;
        --surface: #f3f3f3;
        --ink: #121212;
        --muted: #5b5b5b;
        --line: #b7b7b7;
        --blue: #00a1dc;
        --deep-blue: #1952d2;
        --white-12: rgba(255, 255, 255, 0.12);
        --radius-xl: 1rem;
        --radius-2xl: 1.5rem;
        --page-pad: clamp(1rem, 4vw, 5rem);
        --service-gap: 1.875rem;
    }

    .page-shell {
        background: var(--bg);
        color: var(--ink);
    }

    .section,
    .about-gap {
        padding-inline: var(--page-pad);
    }

    .hero {
        position: relative;
        min-height: 100svh;
        min-height: 100dvh;
        padding: 5.75rem var(--page-pad) 2.5rem;
        display: flex;
        flex-direction: column;
        overflow: clip;
        color: white;
        background: linear-gradient(
            180deg,
            rgba(0, 41, 107, 0.18),
            rgba(0, 18, 48, 0.18)
        );
    }

    .hero__backdrop,
    .hero__backdrop-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .hero__backdrop-image {
        object-fit: cover;
    }

    .hero__backdrop::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
            linear-gradient(
                180deg,
                rgba(24, 83, 211, 0.28) 0%,
                rgba(24, 83, 211, 0.1) 44%,
                rgba(12, 54, 129, 0.34) 100%
            ),
            linear-gradient(
                180deg,
                rgba(255, 255, 255, 0) 62%,
                rgba(0, 0, 0, 0.06) 100%
            );
    }

    .topbar,
    .hero__meta,
    .hero__wordmark,
    .hero__rig,
    .hero__content {
        position: relative;
        z-index: 1;
    }

    .topbar {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 1rem;
    }

    .topbar__menu,
    .topbar__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .topbar__actions {
        justify-content: flex-end;
    }

    .topbar__brand {
        display: flex;
        justify-content: center;
    }

    .brand-mark {
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 999px;
        background:
            radial-gradient(
                circle at 30% 30%,
                rgba(255, 255, 255, 0.85),
                rgba(255, 255, 255, 0.25) 28%,
                transparent 30%
            ),
            conic-gradient(
                from 180deg,
                rgba(255, 255, 255, 0.35),
                rgba(255, 255, 255, 0.9),
                rgba(255, 255, 255, 0.35)
            );
        box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.45);
    }

    .pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        min-height: 2.625rem;
        padding: 0.75rem 1rem;
        border-radius: 999px;
        border: 1px solid currentColor;
        font-size: 1.125rem;
        line-height: 1;
        text-decoration: none;
        white-space: nowrap;
    }

    .pill--ghost {
        color: white;
        background: transparent;
    }

    .pill--solid {
        color: black;
        background: white;
        border-color: white;
    }

    .pill--outline-dark {
        color: var(--ink);
        border-color: var(--ink);
        background: transparent;
    }

    .pill--blue {
        color: white;
        background: #08a9d9;
        border-color: #08a9d9;
    }

    .hero__meta {
        z-index: 2;
        position: absolute;
        top: 11.5rem;
        right: clamp(2rem, 8.25vw, 7.75rem);
        width: min(20.625rem, calc(100% - (2 * var(--page-pad))));
        font-size: 0.9375rem;
        line-height: 1.6;
        text-align: left;
    }

    .hero__wordmark {
        margin: auto 0 0;
        font-size: clamp(4.2rem, 14vw, 12.75rem);
        line-height: 0.92;
        letter-spacing: -0.05em;
    }

    .hero__rig {
        position: absolute;
        right: 7.25rem;
        top: 7.25rem;
        width: min(57vw, 51rem);
    }

    .hero__rig-image {
        display: block;
        width: 100%;
        height: auto;
    }

    .hero__content {
        margin-top: 14rem;
        width: 100%;
        max-width: none;
        display: grid;
        grid-template-columns: minmax(0, 42.875rem) auto;
        align-items: flex-end;
        gap: 1.5rem;
    }

    .hero__headline {
        margin: 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
		letter-spacing: -0.02em;
	}

    .hero__glossary {
        justify-self: end;
        align-self: end;
    }

    .about-gap {
        min-height: 40rem;
        padding-top: 3.1875rem;
        padding-bottom: 3.5rem;
        display: grid;
        align-content: start;
    }

    .about-gap__copy {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 6.5rem;
        align-items: start;
    }

    .about-gap__intro {
        max-width: 39.25rem;
    }

    .about-gap__tag {
        margin-bottom: 1.25rem;
    }

    .about-gap__lead,
    .about-gap__body {
        margin: 0;
        font-size: 2rem;
        line-height: 1.12;
        letter-spacing: -0.02em;
    }

    .about-gap__aside {
        padding-top: 12.5rem;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 5.25rem;
    }

    .about-gap__body {
        max-width: 39.25rem;
    }

    .about-gap__cta {
        color: #1e1e1e;
    }

    [data-reveal-root] [data-reveal] {
        opacity: 0;
        transform: translate3d(0, 2rem, 0);
        transition:
            opacity 1100ms cubic-bezier(0.22, 1, 0.36, 1),
            transform 1100ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--reveal-delay, 0ms);
        will-change: opacity, transform;
    }

    [data-reveal-root] [data-reveal-delay="0"] {
        --reveal-delay: 0ms;
    }

    [data-reveal-root] [data-reveal-delay="120"] {
        --reveal-delay: 120ms;
    }

    [data-reveal-root] [data-reveal-delay="240"] {
        --reveal-delay: 240ms;
    }

    [data-reveal-root].is-visible [data-reveal] {
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }

    .section {
        padding-top: 5rem;
        padding-bottom: 5rem;
    }

    .section-tag {
        margin: 0 0 0.75rem;
        font-size: 1.25rem;
        color: var(--blue);
    }

    .section-tag--center {
        text-align: center;
    }

    .section-tag--inverse {
        color: rgba(255, 255, 255, 0.76);
    }

    .section__intro,
    .approach {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem 2rem;
        align-items: end;
    }

    .section__intro h2,
    .approach h2,
    .contact h2 {
        margin: 0;
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
    }

    .section__intro p:last-child,
    .approach > p:last-child {
        margin: 0;
        font-size: 1.25rem;
        line-height: 1.35;
        color: var(--muted);
    }

    .industry-card__body p,
    .blog-card p,
    .contact address {
        margin: 0;
        font-size: 1.25rem;
        line-height: 1.35;
        color: var(--ink);
    }

    .industry-card__image,
    .industry-card__img {
        width: 100%;
        height: 100%;
    }

    .industry-card__img {
        display: block;
        object-fit: cover;
    }

    .industry-card__image {
        overflow: hidden;
        min-height: 0;
        border: 1px solid #b0b0b0;
        border-radius: 0.5rem;
    }

    .industry-card__img {
        width: 100%;
        height: 100%;
        object-position: center;
    }

    .approach {
        max-width: 39.25rem;
        margin-inline: auto;
        grid-template-columns: 1fr;
        text-align: left;
        justify-items: start;
    }

    .industry-stack-shell {
        margin-top: 1.5rem;
        padding: 0;
        overflow: visible;
    }

    .industry-stack {
        --industry-card-height: 37.5rem;
        --industry-stack-offset: 1rem;
        position: relative;
        height: var(--industry-card-height);
        overflow-y: auto;
        overflow-x: hidden;
        border-radius: 0;
        padding-bottom: 0;
    }

    .industry-card {
        position: sticky;
        top: 0;
        z-index: calc(10 + var(--industry-index));
        height: var(--industry-card-height);
        margin-top: calc(var(--industry-index) * var(--industry-stack-offset));
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0;
        border-radius: 0.75rem;
        overflow: visible;
        box-shadow: 0 1.25rem 3rem rgba(13, 25, 43, 0.08);
    }

    .industry-card__summary {
        display: flex;
        flex-direction: column;
        padding: 1rem 1rem 0;
        background: var(--panel-accent);
        overflow: hidden;
        border: 1px solid #b0b0b0;
        border-radius: 0.5rem;
    }

    .industry-card__summary h3 {
        margin: 0 0 1.5rem;
        font-size: clamp(2rem, 4vw, 2.75rem);
        line-height: 1.02;
        letter-spacing: -0.03em;
    }

    .industry-card__icon {
        position: relative;
        width: 3.375rem;
        height: 3.375rem;
        margin-bottom: 0.875rem;
        mix-blend-mode: multiply;
    }

    .industry-card__icon img {
        position: absolute;
        inset: 0;
        display: block;
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .industry-card__summary ul {
        flex: 1 1 auto;
        list-style: none;
        padding: 0;
        width: calc(100% + 2rem);
        margin: 0 -1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1rem;
        background: #f3f3f3;
        border-top: 1px solid #b0b0b0;
    }

    .industry-card__summary li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 1.125rem;
        border-radius: 999px;
        border: 1px solid #dfdfdf;
        backdrop-filter: blur(2px);
        background: rgba(255, 255, 255, 0.18);
        font-size: 1.125rem;
        line-height: 1.1;
    }

    .industry-card__summary li span {
        flex: 1 1 auto;
    }

    .industry-card__summary li img {
        flex: 0 0 auto;
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        object-fit: cover;
    }

    .industry-card__detail {
        display: grid;
        grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
        min-height: 0;
        gap: 0;
        margin-left: -1px;
    }

    .industry-card__body {
        padding: 1rem;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        min-height: 0;
        margin-top: -1px;
        background: #f3f3f3;
        border: 1px solid #b0b0b0;
        border-radius: 0.5rem;
    }

    .contact {
        margin-top: 5rem;
        padding: 5rem var(--page-pad) 2.5rem;
        color: white;
        background:
            radial-gradient(
                circle at 82% 30%,
                rgba(255, 255, 255, 0.12),
                transparent 0 17rem
            ),
            radial-gradient(
                circle at 89% 35%,
                rgba(255, 255, 255, 0.1),
                transparent 0 24rem
            ),
            linear-gradient(122deg, #01a1dc 0%, #1952d2 100%);
        overflow: clip;
    }

    .contact__inner {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 2rem;
        align-items: center;
    }

    .contact__copy {
        max-width: 39.25rem;
    }

    .contact address {
        margin-top: 10rem;
        max-width: 20.625rem;
        color: white;
        font-style: normal;
    }

    .contact__form {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.75rem;
    }

    .contact__grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        width: 100%;
    }

    .contact label {
        width: 100%;
    }

    .contact input,
    .contact textarea {
        width: 100%;
        border: 1px solid rgba(255, 255, 255, 0.9);
        border-radius: 1rem;
        background: var(--white-12);
        color: white;
        padding: 1.5rem 1.25rem;
        font: inherit;
        resize: vertical;
        box-sizing: border-box;
    }

    .contact textarea {
        min-height: 8.75rem;
    }

    .contact input::placeholder,
    .contact textarea::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    .footer {
        margin-top: 8.75rem;
        padding-top: 2.5rem;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 1.5rem;
        align-items: center;
        font-size: 1rem;
    }

    .footer__links,
    .footer__socials {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.75rem;
    }

    .footer__links a,
    .footer__company {
        color: rgba(241, 245, 236, 0.95);
    }

    .footer__socials a {
        color: white;
        text-decoration: none;
    }

    .footer__company {
        text-align: right;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
    }

    @media (max-width: 72rem) {
        .topbar {
            grid-template-columns: 1fr;
        }

        .topbar__menu,
        .topbar__actions,
        .topbar__brand {
            justify-content: center;
        }

        .hero__meta {
            position: relative;
            top: auto;
            right: auto;
            width: min(20.625rem, 100%);
            margin-top: 3.75rem;
            text-align: left;
        }

        .hero__rig {
            position: relative;
            right: auto;
            top: auto;
            width: 100%;
            max-width: 44rem;
            margin: 2rem auto 0;
        }

        .hero__content,
        .section__intro,
