---
import BlogSection from '../components/BlogSection.astro';
import Layout from '../layouts/Layout.astro';

const heroImage = '/figma/blog-hero-image.png';
const blogCardA = '/figma/blog-card-feature-a.png';
const blogCardB = '/figma/blog-card-feature-b.png';
const footerShape = '/figma/blog-contact-shape.svg';

const featuredPost = {
	tag: 'Industry',
	title: 'Get To Know the Metocean Study, Assess Extreme Weather Risk for Your Project',
	excerpt:
		'Metocean is concerned with understanding meteorological and oceanographic conditions at an engineering, or renewable energy, project site.',
	image: heroImage,
};

const latestPosts = [
	{
		tag: 'Products',
		title: 'Get To Know the Metocean Study, Assess Extreme Weather Risk for Your Project',
		excerpt:
			'Metocean is concerned with understanding meteorological and oceanographic conditions at an engineering, or renewable energy, project site.',
		image: blogCardA,
		variant: 'metocean',
		href: '/insight/metocean-study-extreme-weather-risk',
	},
	{
		tag: 'Projects',
		title: 'Smarter Land Decisions Start Here: Discover the Power of Land Forecasting',
		excerpt:
			'In dynamic and weather-sensitive sectors such as maritime operations, energy production, and resource exploration, atmospheric conditions are far more than a backdrop.',
		image: heroImage,
		variant: 'land',
		href: '/insight/smarter-land-decisions-start-here',
	},
	{
		tag: 'Projects',
		title: 'Navigating Disaster Resilience: Flood and Tsunami Early Warning Systems with Machine Learning',
		excerpt:
			'PT Bhumi Warih Geohydromatics supported the development of an Early Warning System platform for floods and tsunamis in the Palu region.',
		image: blogCardB,
		variant: 'warning',
		href: '/insight/disaster-resilience-early-warning-systems',
	},
	{
		tag: 'Science and Technology',
		title: 'The Future is Bright: Unlocking Indonesia’s Solar Potential',
		excerpt:
			'Recent studies highlight the enormous renewable energy potential that Indonesia can harness through geospatial analysis and financial modelling.',
		image: blogCardA,
		variant: 'solar',
		href: '/insight/unlocking-indonesia-solar-potential',
	},
];

const listPosts = [
	{
		tag: 'Products',
		title: 'Get To Know the Metocean Study, Assess Extreme Weather Risk for Your Project',
		excerpt:
			'Metocean is concerned with understanding meteorological and oceanographic conditions at an engineering, or renewable energy, project site.',
		href: '/insight/metocean-study-extreme-weather-risk',
	},
	{
		tag: 'Products',
		title: 'Get To Know the Metocean Study, Assess Extreme Weather Risk for Your Project',
		excerpt:
			'Metocean is concerned with understanding meteorological and oceanographic conditions at an engineering, or renewable energy, project site.',
		href: '/insight/metocean-study-extreme-weather-risk',
	},
	{
		tag: 'Products',
		title: 'Get To Know the Metocean Study, Assess Extreme Weather Risk for Your Project',
		excerpt:
			'Metocean is concerned with understanding meteorological and oceanographic conditions at an engineering, or renewable energy, project site.',
		href: '/insight/metocean-study-extreme-weather-risk',
	},
];

const sections = [
	{
		title: 'Products',
		feature: {
			tag: 'Projects',
			title: 'Navigating Disaster Resilience: Flood and Tsunami Early Warning Systems with Machine Learning',
			excerpt:
				'PT Bhumi Warih Geohydromatics supported by our expert, in collaboration with PT Telkom Indonesia and PT Metra-Net, has successfully developed an Early Warning System platform for floods and tsunamis in the Palu region.',
			image: blogCardB,
			tone: 'mono',
			href: '/insight/disaster-resilience-early-warning-systems',
		},
		list: listPosts,
	},
	{
		title: 'Projects',
		feature: {
			tag: 'Projects',
			title: 'Navigating Disaster Resilience: Flood and Tsunami Early Warning Systems with Machine Learning',
			excerpt:
				'PT Bhumi Warih Geohydromatics supported by our expert, in collaboration with PT Telkom Indonesia and PT Metra-Net, has successfully developed an Early Warning System platform for floods and tsunamis in the Palu region.',
			image: heroImage,
			tone: 'layered',
			href: '/insight/disaster-resilience-early-warning-systems',
		},
		list: listPosts,
	},
	{
		title: 'Company News',
		feature: {
			tag: 'Projects',
			title: 'Navigating Disaster Resilience: Flood and Tsunami Early Warning Systems with Machine Learning',
			excerpt:
				'PT Bhumi Warih Geohydromatics supported by our expert, in collaboration with PT Telkom Indonesia and PT Metra-Net, has successfully developed an Early Warning System platform for floods and tsunamis in the Palu region.',
			image: blogCardB,
			tone: 'mono',
			href: '/insight/disaster-resilience-early-warning-systems',
		},
		list: [
			{
				tag: 'Products',
				title: 'Navigating Disaster Resilience: Flood and Tsunami Early Warning Systems with Machine Learning',
				excerpt:
					'PT Bhumi Warih Geohydromatics supported by our expert, in collaboration with PT Telkom Indonesia and PT Metra-Net.',
				href: '/insight/disaster-resilience-early-warning-systems',
			},
		],
	},
	{
		title: 'Science and Technology',
		feature: {
			tag: 'Projects',
			title: 'Navigating Disaster Resilience: Flood and Tsunami Early Warning Systems with Machine Learning',
			excerpt:
				'PT Bhumi Warih Geohydromatics supported by our expert, in collaboration with PT Telkom Indonesia and PT Metra-Net, has successfully developed an Early Warning System platform for floods and tsunamis in the Palu region.',
			image: heroImage,
			tone: 'layered',
			href: '/insight/disaster-resilience-early-warning-systems',
		},
		list: listPosts,
	},
];
---

<Layout title="Insight | Bhumi Warih" activeNav="insight" footerShape={footerShape}>
	<main class="blog-page">
		<section class="blog-hero" data-nav-hero>
			<div class="blog-hero__media">
				<img src={featuredPost.image} alt="" />
			</div>

			<div class="blog-hero__content">
				<div class="meta-pill">{featuredPost.tag}</div>
				<h1>{featuredPost.title}</h1>
				<p>{featuredPost.excerpt}</p>
				<a href="/insight/metocean-study-extreme-weather-risk" class="pill pill--solid">Read <span aria-hidden="true">→</span></a>
			</div>
		</section>

		<BlogSection
			id="latest"
			posts={latestPosts}
			eyebrow=""
			title="Latest Insights"
			description="Our freshest thoughts on the latest trends -- ongoing, and upcoming."
		/>

		<section class="blog-sections">
			{
				sections.map((section) => (
					<div class="blog-column">
						<h2>{section.title}</h2>
						<article
							class={`feature-card feature-card--${section.feature.tone} feature-card--large`}
							style={`--feature-card-image:url(${section.feature.image})`}
						>
							<div class="meta-pill">{section.feature.tag}</div>
							<div class="feature-card__spacer" aria-hidden="true"></div>
							<div class="feature-card__footer">
								<div class="feature-card__content">
									<h3>{section.feature.title}</h3>
									<p>{section.feature.excerpt}</p>
								</div>
								<a href={section.feature.href} class="pill pill--ghost pill--small">Read More <span aria-hidden="true">→</span></a>
							</div>
						</article>

						<div class="list-panel">
							{
								section.list.map((post) => (
									<article class="list-item">
										<div class="meta-pill meta-pill--dark">{post.tag}</div>
										<h3>{post.title}</h3>
										<p>{post.excerpt}</p>
										<a href={post.href} class="list-item__link">Read More <span aria-hidden="true">→</span></a>
									</article>
								))
							}
							<div class="list-panel__fade"></div>
						</div>
					</div>
				))
			}
		</section>

	</main>
</Layout>

<style>
	:global(:root) {
		--page-pad: clamp(1rem, 4vw, 5rem);
		--line: #dfdfdf;
		--text: #151515;
		--paper: #f8f8f8;
	}

	.blog-page {
		background: white;
		color: var(--text);
	}

	.blog-hero {
		position: relative;
		min-height: 40.875rem;
		color: white;
		overflow: clip;
	}

	.blog-hero__media,
	.blog-hero__media img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.blog-hero__media img {
		object-fit: cover;
	}

	.blog-hero__media::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(0, 128, 207, 0) 48%, rgba(0, 128, 207, 0.8) 100%);
	}

	.topbar,
	.blog-hero__content {
		position: relative;
		z-index: 1;
	}

	.topbar {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		padding: 2rem var(--page-pad) 0;
	}

	.topbar__menu,
	.topbar__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.topbar__actions {
		justify-content: flex-end;
	}

	.topbar__brand {
		display: flex;
		justify-content: center;
	}

	.brand-mark {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 999px;
		background:
			radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.25) 28%, transparent 30%),
			conic-gradient(from 180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0.9), rgba(255, 255, 255, 0.35));
		box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.45);
	}

	.pill {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: 2.625rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		border: 1px solid currentColor;
		font-size: 1.125rem;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.pill--ghost {
		background: transparent;
		color: white;
	}

	.pill--ghost.is-active {
		background: white;
		color: #01a1dc;
		font-weight: 600;
	}

	.pill--solid {
		background: white;
		color: black;
		border-color: white;
	}

	.pill--small {
		min-height: 2.125rem;
		padding: 0.5rem 0.875rem;
		font-size: 0.875rem;
	}

	.meta-pill {
		display: inline-flex;
		align-items: center;
		width: fit-content;
		padding: 0.5rem 0.75rem;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.9);
		background: rgba(255, 255, 255, 0.12);
		font-size: 0.75rem;
		line-height: 1;
	}

	.meta-pill--dark {
		color: black;
		border-color: black;
		background: transparent;
	}

	.blog-hero__content {
		padding: 17rem var(--page-pad) 3rem;
		max-width: 40rem;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
	}

	.blog-hero__content h1,
	.contact h2 {
		margin: 0;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.blog-hero__content p {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.35;
		max-width: 34rem;
	}

	.blog-sections {
		padding-inline: var(--page-pad);
	}

	.blog-column h2 {
		margin: 0;
		font-size: 2rem;
		line-height: 1.12;
	}

	.feature-card {
		position: relative;
		min-height: 25.125rem;
		padding: 1rem;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.75rem;
		border-radius: 0.75rem;
		border: 1px solid #b0b0b0;
		overflow: clip;
		color: white;
		isolation: isolate;
		background: #3b3b3b;
	}

	.feature-card::before,
	.feature-card::after {
		content: '';
		position: absolute;
		inset: 0;
		border-radius: inherit;
	}

	.feature-card::before {
		background:
			var(--feature-card-image) lightgray var(--feature-card-image-position, center) / cover no-repeat;
		filter: var(--feature-card-filter, grayscale(1));
		z-index: 0;
	}

	.feature-card::after {
		background:
			var(--feature-card-overlay-top, linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0) 100%)),
			var(--feature-card-overlay-bottom, linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.32) 100%));
		z-index: 1;
		pointer-events: none;
	}

	.feature-card--large {
		min-height: 25.125rem;
	}

	.feature-card--bright .feature-card__bg::after {
		background: linear-gradient(180deg, rgba(0, 161, 220, 0.1) 0%, rgba(20, 93, 133, 0.9) 78%);
	}

	.feature-card--bright {
		--feature-card-filter: grayscale(1);
		--feature-card-overlay-bottom: linear-gradient(180deg, rgba(0, 161, 220, 0.1) 0%, rgba(20, 93, 133, 0.9) 78%);
	}

	.feature-card--dark,
	.feature-card--mono {
		--feature-card-filter: grayscale(1);
		--feature-card-overlay-bottom: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.32) 100%);
	}

	.feature-card--layered {
		--feature-card-filter: none;
		--feature-card-overlay-top: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.12) 100%);
		--feature-card-overlay-bottom: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.32) 100%);
		--feature-card-image-position: center 42%;
	}

	.feature-card > * {
		position: relative;
		z-index: 2;
	}

	.feature-card .meta-pill {
		padding: 0.375rem 0.5rem;
		border-color: rgba(255, 255, 255, 1);
		background: transparent;
		font-size: 0.625rem;
		line-height: 1;
		letter-spacing: -0.01em;
	}

	.feature-card__spacer {
		flex: 1 1 auto;
		width: 100%;
		min-height: 0;
	}

	.feature-card__footer {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		width: 100%;
	}

	.feature-card__content {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		width: 100%;
	}

	.feature-card__content h3,
	.list-item h3 {
		margin: 0;
		font-size: 2rem;
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.feature-card__content p,
	.list-item p,
	.contact address {
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.12;
	}

	.feature-card .pill {
		min-height: 2.625rem;
		padding: 0.75rem 1rem;
		border-color: rgba(255, 255, 255, 1);
		font-size: 1.125rem;
	}

	.blog-sections {
		padding-top: 2rem;
		padding-bottom: 4rem;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem 1.5rem;
	}

	.blog-column {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.list-panel {
		position: relative;
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 0.75rem;
		padding: 1rem 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		min-height: 25rem;
		overflow: clip;
	}

	.list-item {
		background: white;
		border-radius: 0.75rem;
		padding: 0.75rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.list-item__link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin-top: 0.25rem;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
	}

	.list-panel__fade {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 3rem;
		background: linear-gradient(180deg, rgba(248, 248, 248, 0) 0%, rgba(248, 248, 248, 1) 100%);
	}

	.contact {
		position: relative;
		padding: 5rem var(--page-pad) 2.5rem;
		color: white;
		background: linear-gradient(122deg, #01a1dc 0%, #1952d2 100%);
		overflow: clip;
	}

	.contact__shape {
		position: absolute;
		inset: -6rem auto auto 50%;
		width: min(120rem, 140vw);
		max-width: none;
		transform: translateX(-8%) rotate(90deg);
		opacity: 0.8;
	}

	.contact__inner,
	.footer {
		position: relative;
		z-index: 1;
	}

	.section-tag {
		margin: 0 0 0.875rem;
		font-size: 1.25rem;
		color: #fff;
	}

	.section-tag--inverse {
		color: white;
	}

	.contact__inner {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 2rem;
		align-items: center;
	}

	.contact__copy {
		max-width: 39.25rem;
	}

	.contact address {
		margin-top: 10rem;
		max-width: 20.625rem;
		color: white;
		font-style: normal;
		font-size: 1.25rem;
		line-height: 1.35;
	}

	.contact__form {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.75rem;
	}

	.contact__grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		width: 100%;
	}

	.contact label {
		width: 100%;
	}

	.contact input,
	.contact textarea {
		width: 100%;
		box-sizing: border-box;
		padding: 1.5rem 1.25rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.9);
		background: rgba(255, 255, 255, 0.12);
		color: white;
		font: inherit;
		resize: vertical;
	}

	.contact input::placeholder,
	.contact textarea::placeholder {
		color: rgba(255, 255, 255, 0.55);
	}

	.footer {
		margin-top: 8.75rem;
		padding-top: 2.5rem;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: 1.5rem;
		align-items: center;
		font-size: 1rem;
	}

	.footer__links,
	.footer__socials {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.footer__links a,
	.footer__company {
		color: rgba(241, 245, 236, 0.95);
	}

	.footer__socials a {
		color: white;
		text-decoration: none;
	}

	.footer__company {
		text-align: right;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}

	@media (max-width: 72rem) {
		.topbar,
		.blog-sections,
		.contact__inner,
		.footer {
			grid-template-columns: 1fr;
		}

		.topbar__menu,
		.topbar__actions,
		.topbar__brand {
			justify-content: center;
		}

		.contact__grid {
			grid-template-columns: 1fr;
		}

		.footer__company {
			text-align: left;
		}
	}

	@media (max-width: 40rem) {
		.blog-hero {
			min-height: 28rem;
		}

		.topbar__menu {
			display: none;
		}

		.blog-hero__content {
			padding-top: 11rem;
		}

		.feature-card__content h3 {
			font-size: 1.5rem;
		}

		.contact {
			padding-top: 3rem;
			padding-bottom: 3rem;
		}

		.contact address {
			margin-top: 2rem;
		}

		.footer {
			margin-top: 3rem;
			padding-top: 1rem;
		}
	}
</style>
