---
import { marked } from 'marked';
import BlogSection from '../../components/BlogSection.astro';
import {
	buildReadMoreCards,
	fetchDirectusInsightBySlug,
	fetchDirectusInsights,
	getInsightSeedBySlug,
	getInsightSeedRecords,
	resolveInsightImageUrl,
	type InsightRecord,
} from '../../data/insights';
import { organizationName, toAbsoluteUrl, toMetaDescription } from '../../data/site';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const records = await fetchDirectusInsights().catch((error) => {
		console.error('Failed to load insight slugs from Directus:', error);
		return getInsightSeedRecords();
	});

	return records.map((post) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;
const post =
	(await fetchDirectusInsightBySlug(slug!).catch((error) => {
		console.error(`Failed to load insight "${slug}" from Directus:`, error);
		return null;
	})) ?? getInsightSeedBySlug(slug!);

if (!post) {
	throw new Error(`Insight article not found for slug "${slug}"`);
}

const allPosts = await fetchDirectusInsights().catch((error) => {
	console.error('Failed to load related insights from Directus:', error);
	return getInsightSeedRecords();
});

const readMorePosts = buildReadMoreCards(allPosts, post.slug);
const bodyHtml = await marked.parse(post.body_markdown ?? '');
const heroImage = resolveInsightImageUrl(post.featured_image ?? post.thumbnail);
const footerShape = '/figma/blog-contact-shape.svg';
const articlePath = `/insight/${post.slug}`;
const pageDescription = toMetaDescription(post.seo_description, post.excerpt, post.title);
const pageSchema = [
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: post.title,
		description: pageDescription,
		author: {
			'@type': 'Organization',
			name: organizationName,
		},
		publisher: {
			'@type': 'Organization',
			name: organizationName,
			logo: {
				'@type': 'ImageObject',
				url: toAbsoluteUrl('/apple-touch-icon.png'),
			},
		},
		mainEntityOfPage: toAbsoluteUrl(articlePath),
		url: toAbsoluteUrl(articlePath),
		image: heroImage ? [toAbsoluteUrl(heroImage)] : undefined,
		datePublished: post.published_at ?? undefined,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Insight',
				item: toAbsoluteUrl('/insight'),
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: post.title,
				item: toAbsoluteUrl(articlePath),
			},
		],
	},
];
---

<Layout
	title={`${post.seo_title ?? post.title} | Bhumi Warih`}
	description={pageDescription}
	canonicalPath={articlePath}
	image={heroImage}
	ogType="article"
	activeNav="insight"
	footerShape={footerShape}
	schema={pageSchema}
>
	<main class="article-page">
		<section class="article-hero" data-nav-hero>
			{heroImage && (
				<div class="article-hero__media">
					<img src={heroImage} alt={post.title} />
				</div>
			)}

			<div class="article-hero__inner">
				<p class="article-hero__breadcrumb">Insight / {post.category ?? 'Insight'}</p>
				<h1>{post.title}</h1>
				{post.date_label && <p class="article-hero__meta">{post.date_label}</p>}
			</div>
		</section>

		<article class="article-body">
			<div class="article-body__copy article-body__richtext" set:html={bodyHtml}></div>
		</article>

		<BlogSection
			id="read-more"
			posts={readMorePosts}
			eyebrow=""
			title="Read More"
			description="Our freshest thoughts on the latest trends -- ongoing, and upcoming."
		/>
	</main>
</Layout>

<style>
	.article-page {
		background: #ffffff;
		color: #141414;
	}

	.article-hero {
		position: relative;
		background: #0b3479;
		color: #ffffff;
		padding: 13.75rem clamp(1rem, 5.56vw, 5rem) 3rem;
		overflow: clip;
	}

	.article-hero__media,
	.article-hero__media img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.article-hero__media img {
		object-fit: cover;
	}

	.article-hero__media::after {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(11, 52, 121, 0.32) 0%, rgba(11, 52, 121, 0.88) 100%);
	}

	.article-hero__inner {
		position: relative;
		z-index: 1;
		width: min(100%, 52.75rem);
	}

	.article-hero__breadcrumb,
	.article-hero__meta {
		margin: 0;
		font-family: 'Host Grotesk', 'Inter', sans-serif;
	}

	.article-hero__breadcrumb {
		font-size: clamp(1.25rem, 2vw, 2rem);
		line-height: 1.15;
	}

	.article-hero h1 {
		margin: 1rem 0;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 0.98;
		letter-spacing: -0.03em;
	}

	.article-hero__meta {
		font-size: clamp(1rem, 1.8vw, 1.5rem);
		line-height: 1.12;
	}

	.article-body {
		padding: 2.5rem clamp(1rem, 5.56vw, 5rem) 0;
	}

	.article-body__copy {
		width: min(100%, 52.8125rem);
		font-family: 'Inter', sans-serif;
		font-size: clamp(1rem, 1.6vw, 1.5rem);
		line-height: 1.24;
	}

	.article-body__richtext :is(p, ul, ol, blockquote, pre, table) {
		margin: 0 0 1.5rem;
	}

	.article-body__richtext :is(h2, h3, h4) {
		margin: 2.5rem 0 1rem;
		line-height: 1.08;
		letter-spacing: -0.03em;
	}

	.article-body__richtext h2 {
		font-size: clamp(2rem, 3vw, 3rem);
	}

	.article-body__richtext h3 {
		font-size: clamp(1.5rem, 2.2vw, 2rem);
	}

	.article-body__richtext :is(a, a:visited) {
		color: inherit;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.1em;
	}

	.article-body__richtext ul,
	.article-body__richtext ol {
		padding-left: 1.5rem;
	}

	.article-body__richtext li + li {
		margin-top: 0.5rem;
	}

	.article-body__richtext blockquote {
		margin: 2rem 0;
		padding-left: 1.625rem;
		border-left: 2px solid #6aa7db;
		font-size: clamp(1.125rem, 2.2vw, 2rem);
		line-height: 1.24;
	}

	.article-body__richtext img {
		display: block;
		width: 100%;
		height: auto;
		margin: 2rem 0;
	}

	@media (max-width: 900px) {
		.article-hero {
			padding-top: 9rem;
		}
	}

	@media (max-width: 720px) {
		.article-hero {
			padding-bottom: 2rem;
		}

		.article-body {
			padding-top: 1.5rem;
		}

		.article-body__copy {
			font-size: 1rem;
		}

		.article-body__richtext blockquote {
			padding-left: 1rem;
			font-size: 1.125rem;
		}
	}
</style>
