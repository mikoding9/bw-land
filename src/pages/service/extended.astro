---
import Layout from '../../layouts/Layout.astro';

const heroShape = '/figma/service-extended-hero-wave.svg';
const footerShape = '/figma/service-extended-contact-shape.svg';
const iconSedimentation = '/figma/service-extended-icon-sedimentation.png';
const iconWaterQuality = '/figma/service-extended-icon-water-quality.png';
const iconRemoteSensing = '/figma/service-extended-icon-remote-sensing.png';
const iconBaselineStudy = '/figma/service-extended-icon-baseline-study.png';
const dssImage = '/figma/service-metocean-dss.png';
const extendedImage = '/figma/service-metocean-extended.png';
const serviceOrbitImage = '/figma/home-service-orbit.png';
const iconDroplet = '/figma/icon-droplet.svg';
const iconEarth = '/figma/icon-earth.svg';
const iconPeople = '/figma/icon-people.svg';

const capabilities = [
	{
		title: 'Sedimentation',
		description:
			"Sedimentation analysis is crucial for MetOcean's services, helping to predict sediment transport and deposition patterns. This aids in coastal management and infrastructure planning, ensuring environmental sustainability and operational efficiency.",
		icon: iconSedimentation,
	},
	{
		title: 'Marine Water Quality',
		description:
			'Marine Water Quality assessments by MetOcean leverage advanced modeling techniques, including WRF and WaveWatch III, to predict conditions like winds and currents, ensuring safe and efficient maritime operations.',
		icon: iconWaterQuality,
	},
	{
		title: 'Ocean Remote Sensing',
		description:
			'Ocean Remote Sensing at MetOcean provides precise analysis of historical climate data, focusing on marine locations. We detail winds, waves, currents, and tidal patterns to enhance maritime operations and environmental monitoring.',
		icon: iconRemoteSensing,
	},
	{
		title: 'Environmental Baseline Study',
		description:
			'The Environmental Baseline Study by MetOcean assesses operational windows and downtime probabilities, ensuring optimal performance and minimal disruption in marine environments.',
		icon: iconBaselineStudy,
	},
];

const relatedServices = [
	{
		title: 'Metocean Design Criteria',
		description: 'Extreme Value Analysis. Numerical Simulation. Ocean, Climate and Weather Analysis',
		icon: iconEarth,
		image: serviceOrbitImage,
		href: '/service/metocean',
		tone: 'light-blue',
	},
	{
		title: 'Marine Operation Decision Support System (MO-DSS)',
		description: 'Marine Sea State Prediction. Weather Forecast. Tow Route Forecast. Weather Window.',
		icon: iconDroplet,
		image: dssImage,
		href: '/service/dss',
		tone: 'mist',
	},
	{
		title: 'Extended Services',
		description: 'Our team can provide customized services tailored for your specific needs in maritime industry.',
		icon: iconPeople,
		image: extendedImage,
		href: '/service/extended',
		tone: 'white',
	},
];
---

<Layout
	title="Extended Services | Bhumi Warih"
	activeNav="service"
	footerShape={footerShape}
>
	<main class="service-page">
		<section class="service-hero">
			<div class="service-hero__bg"></div>
			<div class="service-hero__shape-wrap" aria-hidden="true">
				<img class="service-hero__shape" src={heroShape} alt="" />
			</div>
			<div class="service-hero__copy">
				<p class="service-hero__eyebrow">/Service</p>
				<h1>Extended Services</h1>
			</div>
			<p class="service-hero__meta">Registered on CIVD System: SPDA Number 73970/EMP/2024</p>
		</section>

		<section class="service-intro">
			<div class="service-intro__copy">
				<p class="section-tag">About</p>
				<p class="service-intro__lead">
					A business in marine area frequently needs a specific service and only an expert in
					each particular subject is able to conduct the calculations and measurements.
				</p>
				<p>
					We provide our clients with full expert assistance throughout every step of the
					additional services. Our highly skilled and experienced professional consultants have
					helped enable hundreds of clients to achieve success and maximize performance in
					metocean scope or other scope related to metocean.
				</p>
			</div>

			<div class="capability-stack">
				{
					capabilities.map((capability) => (
						<article class="capability-card">
							<div class="capability-card__copy">
								<h2>{capability.title}</h2>
								<p>{capability.description}</p>
							</div>
							<img class="capability-card__icon" src={capability.icon} alt="" />
						</article>
					))
				}
			</div>
		</section>

		<section class="related-services" id="service">
			<div class="related-services__intro">
				<div>
					<p class="section-tag">Services</p>
					<h2>Offshore and Coastal Navigation Decision Making</h2>
				</div>
				<p>
					Make informed decisions through accurate analysis and expert guidance, for safer
					operations, optimized performance, and cost-efficient protection of marine assets.
				</p>
			</div>

			<div class="service-grid">
				{
					relatedServices.map((service, index) => (
						<article class={`service-card service-card--${service.tone} ${index === 1 ? 'service-card--wide' : ''}`}>
							<div class="service-card__copy">
								<img class="service-card__icon-main" src={service.icon} alt="" />
								<h3>{service.title}</h3>
								<p>{service.description}</p>
								<a href={service.href} class="pill pill--outline-dark">Read More <span aria-hidden="true">→</span></a>
							</div>
							<div class="service-card__media">
								<img src={service.image} alt="" />
							</div>
						</article>
					))
				}
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(:root) {
		--page-pad: clamp(1rem, 4vw, 5rem);
		--service-blue: #0080cf;
		--service-accent: #00a1dc;
		--service-line: #d2d5db;
		--service-text: #111111;
		--service-muted: #3d3d3d;
	}

	.service-page {
		background: white;
		color: var(--service-text);
	}

	.service-hero {
		position: relative;
		min-height: 40.8125rem;
		overflow: clip;
		color: white;
	}

	.service-hero__bg {
		position: absolute;
		inset: 0;
		background: var(--service-blue);
	}

	.service-hero__shape-wrap {
		position: absolute;
		inset: 0 auto 0 0;
		width: min(74rem, 86vw);
		overflow: hidden;
	}

	.service-hero__shape {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: auto;
		max-width: none;
		opacity: 0.95;
	}

	.service-hero__copy,
	.service-hero__meta {
		position: relative;
		z-index: 1;
	}

	.service-hero__copy {
		position: absolute;
		left: var(--page-pad);
		bottom: 3.25rem;
		max-width: 44rem;
	}

	.service-hero__eyebrow {
		margin: 0 0 1rem;
		font-size: clamp(1.4rem, 2vw, 2rem);
		line-height: 1.1;
	}

	.service-hero h1 {
		margin: 0;
		font-size: clamp(3.5rem, 7vw, 6rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
	}

	.service-hero__meta {
		position: absolute;
		top: 11.5rem;
		right: clamp(2rem, 8.25vw, 7.75rem);
		width: min(20.625rem, calc(100% - (2 * var(--page-pad))));
		font-size: 1.25rem;
		line-height: 1.25;
	}

	.service-intro,
	.related-services {
		padding: 4rem var(--page-pad) 5rem;
	}

	.service-intro {
		display: grid;
		grid-template-columns: minmax(0, 0.84fr) minmax(0, 1fr);
		gap: clamp(2rem, 4vw, 5rem);
		align-items: start;
	}

	.section-tag {
		margin: 0 0 1rem;
		color: var(--service-accent);
		font-size: 1rem;
		line-height: 1;
	}

	.service-intro__copy {
		max-width: 32.5625rem;
	}

	.service-intro__lead {
		margin: 0 0 1.25rem;
		font-size: clamp(1.75rem, 3vw, 2rem);
		line-height: 1.12;
	}

	.service-intro__copy p:last-child {
		margin: 0;
		font-size: 1rem;
		line-height: 1.45;
		color: var(--service-muted);
	}

	.capability-stack {
		display: grid;
		gap: 0.9rem;
	}

	.capability-card {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.4rem 1.5rem;
		border: 1px solid var(--service-line);
		border-radius: 0.75rem;
		background: white;
	}

	.capability-card__copy {
		flex: 1;
	}

	.capability-card__copy h2 {
		margin: 0 0 0.45rem;
		font-size: 2rem;
		line-height: 1.08;
	}

	.capability-card__copy p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.4;
		color: var(--service-muted);
	}

	.capability-card__icon {
		width: 3.375rem;
		height: 3.375rem;
		flex: none;
	}

	.related-services__intro {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 39.25rem);
		gap: 2rem;
		margin-bottom: 2rem;
		align-items: end;
	}

	.related-services__intro h2 {
		margin: 0;
		max-width: 38rem;
		font-size: clamp(2rem, 4vw, 2.75rem);
		line-height: 1;
		letter-spacing: -0.04em;
	}

	.related-services__intro p {
		margin: 0;
		font-size: 1rem;
		line-height: 1.45;
		color: var(--service-muted);
	}

	.service-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.5rem;
	}

	.service-card {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
		overflow: hidden;
		border-radius: 0.75rem;
		min-height: 23rem;
	}

	.service-card--wide {
		grid-column: span 2;
	}

	.service-card--light-blue .service-card__copy {
		background: rgba(0, 81, 255, 0.08);
	}

	.service-card--mist .service-card__copy {
		background: #e6e7ea;
	}

	.service-card--white .service-card__copy {
		background: rgba(0, 161, 220, 0.08);
	}

	.service-card__copy {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.875rem;
		padding: 1.5rem;
	}

	.service-card__icon-main {
		width: 3rem;
		height: 3rem;
	}

	.service-card__copy h3 {
		margin: 0;
		font-size: clamp(2rem, 4vw, 2.25rem);
		line-height: 1.05;
	}

	.service-card__copy p {
		margin: 0;
		max-width: 18rem;
		font-size: 1rem;
		line-height: 1.4;
	}

	.service-card__media {
		position: relative;
		overflow: hidden;
		min-height: 19rem;
	}

	.service-card__media img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		min-height: 2.625rem;
		padding: 0.75rem 1rem;
		border-radius: 999px;
		font-size: 1.125rem;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.pill--outline-dark {
		border: 1px solid currentColor;
		color: #101010;
	}

	@media (max-width: 72rem) {
		.service-hero__shape-wrap {
			width: min(62rem, 98vw);
		}

		.service-intro,
		.related-services__intro,
		.service-grid {
			grid-template-columns: 1fr;
		}

		.service-card--wide {
			grid-column: auto;
		}

		.service-card {
			grid-template-columns: 1fr;
		}

		.service-card__copy p {
			max-width: none;
		}
	}

	@media (max-width: 56rem) {
		.service-hero {
			min-height: 30rem;
		}

		.service-hero__shape-wrap {
			width: 100vw;
		}

		.service-hero__copy {
			position: relative;
			left: auto;
			bottom: auto;
			padding: 10rem var(--page-pad) 0;
		}

		.service-hero__meta {
			position: relative;
			top: auto;
			right: auto;
			width: min(20.625rem, 100%);
			padding: 0 var(--page-pad) 2rem;
		}
	}

	@media (max-width: 40rem) {
		.service-intro,
		.related-services {
			padding-top: 3rem;
			padding-bottom: 3rem;
		}

		.capability-card {
			padding: 1rem;
		}

		.capability-card__icon {
			width: 2.5rem;
			height: 2.5rem;
		}

		.service-card__media img {
			position: static;
			height: auto;
		}
	}
</style>
