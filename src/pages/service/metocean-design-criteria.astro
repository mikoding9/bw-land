---
import ServicesSection from '../../components/ServicesSection.astro';
import { fetchDirectusPage } from '../../data/directus';
import { services, type ServiceItem } from '../../data/services';
import { toAbsoluteUrl, toMetaDescription } from '../../data/site';
import servicePageFallback from '../../data/page-content/service-metocean-design-criteria.json';
import Layout from '../../layouts/Layout.astro';

const heroShape = '/figma/service-metocean-hero-wave.svg';
const footerShape = '/figma/service-metocean-contact-shape.svg';
const atlasImage = '/figma/service-metocean-atlas.png';
const directionalImage = '/figma/service-metocean-directional.png';
const simulationImage = '/figma/service-metocean-simulation.png';
const extremeImage = '/figma/service-metocean-extreme.png';
const fallbackStudies = [
	{
		title: 'Metocean Atlas',
		description:
			'Metocean Atlas (map) of physical parameters (wind, wave, currents, and tides) in coastal and ocean environments.',
		image: atlasImage,
		tone: 'white',
	},
	{
		title: 'Directional Analysis',
		description:
			'Directional analyses of long-term winds, waves, and currents in coastal and ocean environments.',
		image: directionalImage,
		tone: 'mist',
	},
	{
		title: 'Numerical Simulations',
		description:
			'Simulation of waves, currents, and tides, and conception from several scenarios that could occur on work sites.',
		image: simulationImage,
		tone: 'lime',
	},
	{
		title: 'Extreme Values Analysis',
		description:
			'Using a vast amount of historical data, extreme values analysis gives prediction of extreme events from waves, currents, and tides on work sites.',
		image: extremeImage,
		tone: 'white',
	},
];

const fallbackPage = await fetchDirectusPage('service-metocean-design-criteria').catch((error) => {
	console.error('Failed to load metocean design criteria page content from Directus:', error);
	return null;
});

const pageRecord = fallbackPage ?? {
	seo_title: servicePageFallback.seo.title,
	hero_eyebrow: servicePageFallback.hero.eyebrow,
	hero_title: servicePageFallback.hero.title,
	hero_meta: servicePageFallback.hero.meta,
	sections: servicePageFallback.sections,
};

const sectionById = Object.fromEntries((pageRecord.sections ?? []).map((section) => [section.id, section]));
const aboutSection = sectionById.about ?? servicePageFallback.sections.find((section) => section.id === 'about');
const relatedServicesSection = sectionById.related_services ?? servicePageFallback.sections.find((section) => section.id === 'related_services');
const studies = Array.isArray(aboutSection?.items) ? aboutSection.items : fallbackStudies;
const relatedServices: ServiceItem[] = Array.isArray(relatedServicesSection?.items)
	? relatedServicesSection.items.map((item) => ({
			slug: item.slug,
			title: item.title,
			description: item.description,
			icon: item.icon,
			image: item.image,
			tone: item.tone,
		}))
	: services;
const pageDescription = toMetaDescription(aboutSection?.lead, aboutSection?.body, relatedServicesSection?.description);
const pageSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: pageRecord.seo_title ?? 'MetOcean Design Criteria | Bhumi Warih',
	description: pageDescription,
	url: toAbsoluteUrl('/service/metocean-design-criteria'),
};

---

<Layout
	title={pageRecord.seo_title ?? 'MetOcean Design Criteria | Bhumi Warih'}
	description={pageDescription}
	canonicalPath="/service/metocean-design-criteria"
	image={atlasImage}
	activeNav="service"
	footerShape={footerShape}
	schema={pageSchema}
>
	<main class="service-page">
		<section class="service-hero" data-nav-hero>
			<div class="service-hero__bg"></div>
			<div class="service-hero__shape-wrap" aria-hidden="true">
				<img class="service-hero__shape" src={heroShape} alt="" />
			</div>
			<div class="service-hero__copy">
				<p class="service-hero__eyebrow">{pageRecord.hero_eyebrow ?? servicePageFallback.hero.eyebrow}</p>
				<h1>{pageRecord.hero_title ?? servicePageFallback.hero.title}</h1>
			</div>
			<p class="service-hero__meta">{pageRecord.hero_meta ?? servicePageFallback.hero.meta}</p>
		</section>

		<section class="service-intro">
			<div class="service-intro__copy">
				<p class="section-tag">{aboutSection.eyebrow}</p>
				<p class="service-intro__lead">{aboutSection.lead}</p>
				<p>{aboutSection.body}</p>
			</div>

			<div class="study-stack">
				{
					studies.map((study) => (
						<article class={`study-card study-card--${study.tone}`}>
							<div class="study-card__media">
								<img src={study.image} alt={study.title} />
							</div>
							<div class="study-card__body">
								<h2>{study.title}</h2>
								<p>{study.description}</p>
							</div>
						</article>
					))
				}
			</div>
		</section>

		<ServicesSection
			eyebrow={relatedServicesSection.eyebrow}
			title={relatedServicesSection.title}
			description={relatedServicesSection.description}
			services={relatedServices}
		/>
	</main>
</Layout>

<style>
	:global(:root) {
		--page-pad: clamp(1rem, 4vw, 5rem);
		--service-blue: #044ecc;
		--service-accent: #00a1dc;
		--service-line: #b0b0b0;
		--service-text: #111111;
		--service-muted: #3d3d3d;
	}

	.service-page {
		background: white;
		color: var(--service-text);
	}

	.service-hero {
		position: relative;
		min-height: 40.8125rem;
		overflow: clip;
		color: white;
	}

	.service-hero__bg {
		position: absolute;
		inset: 0;
		background: var(--service-blue);
	}

	.service-hero__shape-wrap {
		position: absolute;
		inset: 0 auto 0 0;
		width: min(74rem, 86vw);
		overflow: hidden;
	}

	.service-hero__shape {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: auto;
		max-width: none;
		opacity: 0.95;
	}

	.service-hero__copy,
	.service-hero__meta {
		position: relative;
		z-index: 1;
	}

	.service-hero__copy {
		position: absolute;
		left: var(--page-pad);
		bottom: 3.25rem;
		max-width: 44rem;
	}

	.service-hero__eyebrow {
		margin: 0 0 1rem;
		font-size: clamp(1.4rem, 2vw, 2rem);
		line-height: 1.1;
	}

	.service-hero h1 {
		margin: 0;
		font-size: clamp(3.5rem, 7vw, 6rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
	}

	.service-hero__meta {
		position: absolute;
		top: 11.5rem;
		right: clamp(2rem, 8.25vw, 7.75rem);
		width: min(20.625rem, calc(100% - (2 * var(--page-pad))));
		font-size: 1.25rem;
		line-height: 1.25;
	}

	.service-intro {
		padding: 4rem var(--page-pad) 5rem;
	}

	.service-intro {
		display: grid;
		grid-template-columns: minmax(0, 0.86fr) minmax(0, 1fr);
		gap: clamp(2rem, 3.5vw, 4.5rem);
		align-items: start;
	}

	.section-tag {
		margin: 0 0 1rem;
		color: var(--service-accent);
		font-size: 1.25rem;
		line-height: 1;
	}

	.service-intro__copy {
		position: sticky;
		top: 6.5rem;
		align-self: start;
		max-width: 32.4375rem;
	}

	.service-intro__lead {
		margin: 0 0 1.25rem;
		font-size: clamp(1.85rem, 3vw, 2rem);
		line-height: 1.12;
	}

	.service-intro__copy p:last-child {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.25;
		color: var(--service-text);
	}

	.study-stack {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}

	.study-card {
		overflow: hidden;
		border: 1px solid var(--service-line);
		border-radius: 0.75rem;
		background: white;
	}

	.study-card--mist {
		background: #e7e8eb;
	}

	.study-card--lime {
		background: #d4ff00;
	}

	.study-card__media {
		display: grid;
		place-items: center;
		min-height: 31rem;
		padding: 1.75rem;
		border-bottom: 1px solid var(--service-line);
	}

	.study-card__media img {
		max-height: 28rem;
		object-fit: contain;
	}

	.study-card__body {
		padding: 1.5rem;
	}

	.study-card__body h2 {
		margin: 0 0 0.5rem;
		font-size: 2rem;
		line-height: 1.12;
	}

	.study-card__body p {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.25;
	}

	@media (max-width: 72rem) {
		.service-hero__shape-wrap {
			width: min(62rem, 98vw);
		}

		.service-intro {
			grid-template-columns: 1fr;
		}

		.service-intro__copy {
			position: static;
		}
	}

	@media (max-width: 56rem) {
		.service-hero {
			min-height: 30rem;
		}

		.service-hero__shape-wrap {
			width: 100vw;
		}

		.service-hero__copy {
			position: relative;
			left: auto;
			bottom: auto;
			padding: 10rem var(--page-pad) 0;
		}

		.service-hero__meta {
			position: relative;
			top: auto;
			right: auto;
			width: min(20.625rem, 100%);
			padding: 0 var(--page-pad) 2rem;
		}

		.study-card__media {
			min-height: 18rem;
		}
	}

	@media (max-width: 40rem) {
		.service-intro {
			padding-top: 3rem;
			padding-bottom: 3rem;
		}

		.service-intro__copy p:last-child,
		.study-card__body p {
			font-size: 1rem;
			line-height: 1.4;
		}
	}
</style>
