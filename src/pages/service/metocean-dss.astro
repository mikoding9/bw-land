---
import ServicesSection from '../../components/ServicesSection.astro';
import { services } from '../../data/services';
import Layout from '../../layouts/Layout.astro';

const heroShape = '/figma/service-dss-hero-wave.svg';
const footerShape = '/figma/service-dss-contact-shape.svg';
const forecast7Image = '/figma/service-dss-forecast-7.png';
const forecast10Image = '/figma/service-dss-forecast-10.png';
const climatologyImage = '/figma/service-dss-climatology.png';
const weatherWindowImage = '/figma/service-dss-weather-window.png';
const cardIconForecast = '/figma/service-dss-card-icon-forecast.png';
const cardIconAnalysis = '/figma/service-dss-card-icon-analysis.png';
const solutions = [
	{
		title: 'Marine Sea State Prediction (7 Days Ahead)',
		description:
			'Prognosis of 7-days ahead winds, waves, swells, and currents. The prognosis is based on downscaling method using Weather Research and Forecasting model (WRF), in-house hydrodynamic model, and WaveWatch III.',
		image: forecast7Image,
		icon: cardIconForecast,
	},
	{
		title: 'Marine Sea State Prediction (10 Days Ahead)',
		description:
			'Prognosis of 10-days ahead winds, waves, swells, and currents. The prognosis is based on downscaling method using Weather Research and Forecasting model (WRF), in-house hydrodynamic model, and WaveWatch III.',
		image: forecast10Image,
		icon: cardIconForecast,
	},
	{
		title: 'Climatology Analysis',
		description:
			'Analysis of historical climate data for specific marine locations; detailing winds, waves, currents, and tidal patterns.',
		image: climatologyImage,
		icon: cardIconAnalysis,
	},
	{
		title: 'Weather Window',
		description:
			'Analysis of operation window and assessment of down time (work standby) probability.',
		image: weatherWindowImage,
		icon: cardIconAnalysis,
	},
];

---

<Layout
	title="MetOcean DSS | Bhumi Warih"
	activeNav="service"
	footerShape={footerShape}
>
	<main class="service-page">
		<section class="service-hero" data-nav-hero>
			<div class="service-hero__bg"></div>
			<div class="service-hero__shape-wrap" aria-hidden="true">
				<img class="service-hero__shape" src={heroShape} alt="" />
			</div>
			<div class="service-hero__copy">
				<p class="service-hero__eyebrow">/Service</p>
				<h1>MetOcean DSS</h1>
			</div>
			<p class="service-hero__meta">Registered on CIVD System: SPDA Number 73970/EMP/2024</p>
		</section>

		<section class="service-intro">
			<div class="service-intro__copy">
				<p class="section-tag">About</p>
				<p class="service-intro__lead">
					For maritime industry, those parameters are meteorology and oceanography (metocean)
					parameters. As the expansion of maritime industries, reliable metocean parameters
					information are considered a remarkable matter.
				</p>
				<p class="service-intro__body">
					Some operational information is critically dependent on accurate metocean parameters
					information. If we don’t have this information, when bad weather, say, a storm comes,
					we will not have any idea what kind of decision we have to take to save our assets. A
					better decision can be taken if we have predicted such bad weather. Predicted weather
					condition can give great basic knowledge for all decision makers. Thus, we can prevent
					the damage and reduce the loss.
				</p>
				<p class="service-intro__kicker">
					Natural condition uncertainties come with every man-made plan in maritime activities.
				</p>
			</div>

			<div class="solution-stack">
				{
					solutions.map((solution) => (
						<article class="solution-card">
							<div class="solution-card__media">
								<img src={solution.image} alt={solution.title} />
							</div>
							<div class="solution-card__body">
								<div class="solution-card__copy">
									<h2>{solution.title}</h2>
									<p>{solution.description}</p>
								</div>
								<img class="solution-card__icon" src={solution.icon} alt="" />
							</div>
						</article>
					))
				}
			</div>
		</section>

		<ServicesSection services={services} />
	</main>
</Layout>

<style>
	:global(:root) {
		--page-pad: clamp(1rem, 4vw, 5rem);
		--service-blue: #044ecc;
		--service-accent: #00a1dc;
		--service-line: #b0b0b0;
		--service-text: #111111;
		--service-muted: #3d3d3d;
	}

	.service-page {
		background: white;
		color: var(--service-text);
	}

	.service-hero {
		position: relative;
		min-height: 40.8125rem;
		overflow: clip;
		color: white;
	}

	.service-hero__bg {
		position: absolute;
		inset: 0;
		background: var(--service-blue);
	}

	.service-hero__shape-wrap {
		position: absolute;
		inset: 0 auto 0 0;
		width: min(74rem, 86vw);
		overflow: hidden;
	}

	.service-hero__shape {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: auto;
		max-width: none;
		opacity: 0.95;
	}

	.service-hero__copy,
	.service-hero__meta {
		position: relative;
		z-index: 1;
	}

	.service-hero__copy {
		position: absolute;
		left: var(--page-pad);
		bottom: 3.25rem;
		max-width: 54rem;
	}

	.service-hero__eyebrow {
		margin: 0 0 1rem;
		font-size: clamp(1.4rem, 2vw, 2rem);
		line-height: 1.1;
	}

	.service-hero h1 {
		margin: 0;
		font-size: clamp(3.5rem, 7vw, 6rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
		max-width: 53rem;
	}

	.service-hero__meta {
		position: absolute;
		top: 11.5rem;
		right: clamp(2rem, 8.25vw, 7.75rem);
		width: min(20.625rem, calc(100% - (2 * var(--page-pad))));
		font-size: 1.25rem;
		line-height: 1.25;
	}

	.service-intro {
		padding: 4rem var(--page-pad) 5rem;
	}

	.service-intro {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(0, 1fr);
		gap: clamp(2rem, 3.5vw, 4.5rem);
		align-items: start;
	}

	.section-tag {
		margin: 0 0 1rem;
		color: var(--service-accent);
		font-size: 1.25rem;
		line-height: 1;
	}

	.service-intro__copy {
		position: sticky;
		top: 6.5rem;
		align-self: start;
		max-width: 32.4375rem;
	}

	.service-intro__lead {
		margin: 0 0 1.25rem;
		font-size: clamp(1.85rem, 3vw, 2rem);
		line-height: 1.12;
		color: var(--service-text);
	}

	.service-intro__body,
	.service-intro__kicker {
		margin-top: 0;
		font-size: 1rem;
		line-height: 1.45;
		color: var(--service-muted);
	}

	.service-intro__body {
		margin-bottom: 1rem;
	}

	.service-intro__kicker {
		margin-bottom: 0;
	}

	.solution-stack {
		display: grid;
		gap: 1.5rem;
	}

	.solution-card {
		overflow: hidden;
		border: 1px solid var(--service-line);
		border-radius: 0.75rem;
		background: white;
	}

	.solution-card__media {
		border-bottom: 1px solid var(--service-line);
		background: #f3f5f7;
	}

	.solution-card__media img {
		display: block;
		width: 100%;
		height: 30rem;
		object-fit: cover;
	}

	.solution-card__body {
		display: flex;
		gap: 0.8125rem;
		align-items: flex-start;
		justify-content: space-between;
		padding: 1.5rem;
	}

	.solution-card__copy {
		flex: 1;
	}

	.solution-card__copy h2 {
		margin: 0 0 0.5rem;
		font-size: 2rem;
		line-height: 1.12;
		font-weight: 700;
	}

	.solution-card__copy p {
		margin: 0;
		font-size: 1.25rem;
		line-height: 1.25;
	}

	.solution-card__icon {
		width: 3.375rem;
		height: 3.375rem;
		flex: none;
	}

	@media (max-width: 72rem) {
		.service-hero__shape-wrap {
			width: min(62rem, 98vw);
		}

		.service-intro {
			grid-template-columns: 1fr;
		}

		.service-intro__copy {
			position: static;
		}
	}

	@media (max-width: 56rem) {
		.service-hero {
			min-height: 30rem;
		}

		.service-hero__shape-wrap {
			width: 100vw;
		}

		.service-hero__copy {
			position: relative;
			left: auto;
			bottom: auto;
			padding: 10rem var(--page-pad) 0;
		}

		.service-hero__meta {
			position: relative;
			top: auto;
			right: auto;
			width: min(20.625rem, 100%);
			padding: 0 var(--page-pad) 2rem;
		}

		.solution-card__media img {
			height: 19rem;
		}
	}

	@media (max-width: 40rem) {
		.service-intro {
			padding-top: 3rem;
			padding-bottom: 3rem;
		}

		.solution-card__body {
			padding: 1rem;
		}

		.service-intro__body,
		.service-intro__kicker,
		.solution-card__copy p {
			font-size: 1rem;
			line-height: 1.4;
		}

		.solution-card__copy h2 {
			font-size: 1.5rem;
		}

		.solution-card__icon {
			width: 2.5rem;
			height: 2.5rem;
		}
	}
</style>
